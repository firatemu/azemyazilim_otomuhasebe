    "@mui/material-nextjs": "^7.3.3",
    "@mui/x-data-grid": "^8.16.0",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
