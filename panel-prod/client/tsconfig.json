{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true, // Library type check'lerini atla - daha hızlı
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true, // Incremental compilation - daha hızlı rebuild
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo", // Build info cache
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    // PERFORMANS OPTİMİZASYONLARI
    "assumeChangesOnlyAffectDirectDependencies": true, // Sadece direkt bağımlılıkları kontrol et
    "disableSourceOfProjectReferenceRedirect": true, // Project reference redirect'i kapat
    "disableSolutionSearching": true, // Solution searching'i kapat (daha hızlı)
    "disableReferencedProjectLoad": true // Referenced project'leri yükleme (daha hızlı)
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next/dev/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build"
  ]
}
