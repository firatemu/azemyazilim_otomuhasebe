FROM node:20-alpine
WORKDIR /app/server

RUN apk add --no-cache openssl

# Build context is api-stage, so paths are relative to that
COPY server/package.json server/pnpm-lock.yaml* server/package-lock.json* ./
RUN corepack enable && (pnpm i || npm ci || npm i)

COPY server/prisma ./prisma

# Generate client (dummy URL for build)
ENV DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy?schema=public"
RUN npx prisma generate

CMD ["npx", "prisma", "migrate", "deploy"]
