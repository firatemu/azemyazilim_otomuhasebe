{
  "prompt": {
    "title": "Satın Alma Sipariş ve Fatura Modülü - Cursor Prompt",
    "context": {
      "stack": "Next.js 16, React 19, TypeScript, MUI 7, TanStack Query, Zustand, NestJS 11, Prisma 6, PostgreSQL",
      "existing_module": "Satın Alma Faturası modülü mevcut (referans alınacak)"
    },
    "business_scenarios": [
      {
        "scenario": "Tam Teslimat",
        "flow": [
          "X firmasından 10 adet A ürünü sipariş oluştur",
          "10 adet geldi → MEVCUT Satın Alma Faturası arayüzü ile fatura oluştur",
          "Sipariş durumu: COMPLETED"
        ]
      },
      {
        "scenario": "Kısmi Teslimat + Farklı Tedarikçiden Tamamlama",
        "flow": [
          "X firmasından 10 adet A ürünü sipariş oluştur",
          "X firmasında sadece 5 adet var → 5 adet için fatura oluştur",
          "Sipariş durumu: PARTIAL (kalan: 5 adet)",
          "Kalan 5 adet için Y firmasından yeni sipariş oluştur",
          "Y firmasından 5 adet için fatura oluştur",
          "Her iki sipariş de COMPLETED"
        ]
      }
    ],
    "tasks": [
      {
        "step": 1,
        "name": "MEVCUT SATIN ALMA FATURASI MODÜLÜNÜ ANALİZ ET",
        "priority": "CRITICAL",
        "description": "Önce mevcut Satın Alma Faturası modülünü bul ve analiz et",
        "sub_tasks": [
          "Hangi dosyalarda bulunuyor (frontend + backend)?",
          "Component yapısı nedir?",
          "Form validasyonları neler?",
          "API endpoint'leri neler?",
          "Arayüz tasarımı nasıl (layout, tablo, butonlar)?",
          "State management nasıl yapılmış?",
          "Bu arayüzü BİREBİR AYNI şekilde sipariş → fatura akışında kullanacağız"
        ]
      },
      {
        "step": 2,
        "name": "PRİSMA SCHEMA TASARLA",
        "models": [
          {
            "name": "PurchaseOrder",
            "fields": [
              "id: String @id @default(uuid())",
              "orderNumber: String @unique",
              "supplierId: String",
              "orderDate: DateTime @default(now())",
              "expectedDeliveryDate: DateTime",
              "status: OrderStatus @default(PENDING)",
              "totalAmount: Decimal",
              "notes: String?",
              "items: PurchaseOrderItem[]",
              "invoices: PurchaseInvoice[]",
              "createdAt: DateTime @default(now())",
              "updatedAt: DateTime @updatedAt"
            ]
          },
          {
            "name": "PurchaseOrderItem",
            "fields": [
              "id: String @id @default(uuid())",
              "purchaseOrderId: String",
              "productId: String",
              "orderedQuantity: Int",
              "receivedQuantity: Int @default(0)",
              "unitPrice: Decimal",
              "status: OrderItemStatus @default(PENDING)",
              "invoiceItems: PurchaseInvoiceItem[]"
            ],
            "computed_fields": [
              "remainingQuantity = orderedQuantity - receivedQuantity"
            ]
          },
          {
            "name": "OrderStatus",
            "type": "enum",
            "values": ["PENDING", "PARTIAL", "COMPLETED", "CANCELLED"]
          },
          {
            "name": "OrderItemStatus",
            "type": "enum",
            "values": ["PENDING", "PARTIAL", "COMPLETED"]
          },
          {
            "name": "PurchaseInvoice",
            "action": "EXTEND_EXISTING",
            "new_fields": [
              "purchaseOrderId: String?",
              "purchaseOrder: PurchaseOrder? @relation"
            ]
          },
          {
            "name": "PurchaseInvoiceItem",
            "action": "EXTEND_EXISTING",
            "new_fields": [
              "purchaseOrderItemId: String?",
              "purchaseOrderItem: PurchaseOrderItem? @relation"
            ]
          }
        ]
      },
      {
        "step": 3,
        "name": "BACKEND NestJS MODÜLÜ",
        "module_name": "purchase-orders",
        "endpoints": [
          {
            "method": "POST",
            "path": "/purchase-orders",
            "description": "Sipariş oluştur"
          },
          {
            "method": "GET",
            "path": "/purchase-orders",
            "description": "Sipariş listesi (filtreleme ile)"
          },
          {
            "method": "GET",
            "path": "/purchase-orders/:id",
            "description": "Sipariş detay"
          },
          {
            "method": "PATCH",
            "path": "/purchase-orders/:id",
            "description": "Sipariş güncelle"
          },
          {
            "method": "DELETE",
            "path": "/purchase-orders/:id",
            "description": "Sipariş sil"
          },
          {
            "method": "GET",
            "path": "/purchase-orders/:id/remaining-items",
            "description": "Kalan miktarları getir"
          },
          {
            "method": "POST",
            "path": "/purchase-orders/:id/create-invoice",
            "description": "Sipariş → Fatura dönüşümü"
          },
          {
            "method": "POST",
            "path": "/purchase-orders/from-remaining",
            "description": "Kalan miktarlardan yeni sipariş"
          },
          {
            "method": "GET",
            "path": "/purchase-orders/:id/invoices",
            "description": "Siparişe ait faturalar"
          }
        ],
        "business_logic": [
          "Sipariş durumu otomatik güncelleme (tüm item'lar tamamsa COMPLETED, kısmi teslim varsa PARTIAL)",
          "Fatura oluşturulunca ilgili sipariş item'larının receivedQuantity güncellemesi",
          "remainingQuantity hesaplama (orderedQuantity - receivedQuantity)",
          "Sipariş numarası otomatik üretimi (örn: PO-2025-00001)"
        ],
        "dtos": [
          "CreatePurchaseOrderDto",
          "UpdatePurchaseOrderDto",
          "CreateInvoiceFromOrderDto",
          "CreateOrderFromRemainingDto",
          "PurchaseOrderFilterDto"
        ]
      },
      {
        "step": 4,
        "name": "FRONTEND SAYFA YAPISI",
        "routes": [
          {
            "path": "/purchase-orders",
            "file": "page.tsx",
            "description": "Liste sayfası - DataGrid ile"
          },
          {
            "path": "/purchase-orders/new",
            "file": "new/page.tsx",
            "description": "Yeni sipariş oluşturma formu"
          },
          {
            "path": "/purchase-orders/[id]",
            "file": "[id]/page.tsx",
            "description": "Sipariş detay görünümü"
          },
          {
            "path": "/purchase-orders/[id]/edit",
            "file": "[id]/edit/page.tsx",
            "description": "Sipariş düzenleme"
          },
          {
            "path": "/purchase-orders/[id]/create-invoice",
            "file": "[id]/create-invoice/page.tsx",
            "description": "FATURAYA DÖNÜŞTÜR - MEVCUT FATURA ARAYÜZÜ İLE BİREBİR AYNI",
            "critical": true
          }
        ]
      },
      {
        "step": 5,
        "name": "FRONTEND COMPONENT'LER",
        "components": [
          {
            "name": "PurchaseOrderList",
            "description": "Liste Sayfası",
            "features": [
              "MUI DataGrid ile sipariş listesi",
              "Kolonlar: Sipariş No, Tedarikçi, Tarih, Toplam Tutar, Durum, İşlemler",
              "Durum badge'leri: PENDING (mavi), PARTIAL (turuncu + 'Kalan: X adet'), COMPLETED (yeşil), CANCELLED (kırmızı)",
              "Filtreler: Durum, Tedarikçi, Tarih aralığı",
              "İşlem butonları: Görüntüle, Düzenle, Fatura Oluştur (sadece PENDING/PARTIAL için), Sil"
            ]
          },
          {
            "name": "PurchaseOrderForm",
            "description": "Yeni/Düzenle Formu",
            "features": [
              "Tedarikçi seçimi (Autocomplete)",
              "Beklenen teslim tarihi (DatePicker)",
              "Ürün ekleme tablosu: Ürün seçimi, Miktar, Birim fiyat, Toplam (otomatik), Satır silme",
              "'Ürün Ekle' butonu",
              "Genel toplam (otomatik hesaplama)",
              "Notlar (textarea)",
              "Kaydet/İptal butonları",
              "React Hook Form + Zod validasyonu"
            ]
          },
          {
            "name": "PurchaseOrderDetail",
            "description": "Detay Sayfası",
            "sections": [
              {
                "name": "Üst Kısım",
                "content": "Sipariş bilgileri card (Sipariş No, Tedarikçi, Tarih, Durum, Toplam)"
              },
              {
                "name": "Orta Kısım",
                "content": "Sipariş kalemleri tablosu",
                "columns": [
                  "Ürün",
                  "Sipariş Miktarı",
                  "Teslim Alınan",
                  "KALAN (vurgulu - turuncu highlight eğer > 0)",
                  "Birim Fiyat",
                  "Toplam"
                ]
              },
              {
                "name": "Alt Kısım",
                "content": "İşlem butonları",
                "buttons": [
                  "'Fatura Oluştur' (PENDING/PARTIAL için)",
                  "'Kalan Miktarlar İçin Yeni Sipariş' (sadece PARTIAL için)",
                  "'Düzenle' (sadece PENDING için)",
                  "'İptal Et'"
                ]
              },
              {
                "name": "Sağ Sidebar",
                "content": "Siparişe ait faturalar listesi (accordion)"
              }
            ]
          },
          {
            "name": "CreateInvoiceFromOrder",
            "description": "Faturaya Dönüştür",
            "critical": "MEVCUT Satın Alma Faturası arayüzünün BİREBİR KOPYASI",
            "features": [
              "Arayüzü aynen kullan (component'leri re-use et)",
              "Form alanları siparişten otomatik doldurulsun: Tedarikçi (readonly), Ürünler tablosu",
              "Miktar alanları EDİTABLE (varsayılan: sipariş miktarı, kullanıcı azaltabilir)",
              "'Kısmi Teslimat' checkbox'ı: İşaretliyse kullanıcı miktarları düzenleyebilir",
              "Kaydet butonuna basınca: 1) Fatura oluştur (purchaseOrderId ekle), 2) Sipariş durumunu güncelle, 3) Başarı mesajı, 4) Sipariş detay sayfasına yönlendir"
            ]
          },
          {
            "name": "CreateOrderFromRemainingDialog",
            "description": "Modal - Kalan Miktarlardan Yeni Sipariş",
            "features": [
              "Orijinal sipariş bilgileri (readonly)",
              "Kalan miktarlar tablosu (readonly)",
              "Yeni tedarikçi seçimi (Autocomplete)",
              "Beklenen teslim tarihi",
              "Hangi kalemleri dahil edeceği seçimi (checkbox'lar)",
              "'Yeni Sipariş Oluştur' butonu"
            ]
          }
        ]
      },
      {
        "step": 6,
        "name": "STATE MANAGEMENT (Zustand Store)",
        "store": {
          "name": "usePurchaseOrderStore",
          "state": [
            "orders: PurchaseOrder[]",
            "selectedOrder: PurchaseOrder | null",
            "filters: { status?: OrderStatus; supplierId?: string; dateRange?: [Date, Date] }"
          ],
          "actions": [
            "setOrders",
            "setSelectedOrder",
            "setFilters",
            "fetchOrders",
            "fetchOrderById",
            "createOrder",
            "updateOrder",
            "deleteOrder",
            "createInvoiceFromOrder",
            "createOrderFromRemaining"
          ]
        }
      },
      {
        "step": 7,
        "name": "TANSTACK QUERY HOOKS",
        "hooks": [
          "useOrders(filters)",
          "useOrder(id)",
          "useCreateOrder()",
          "useUpdateOrder()",
          "useDeleteOrder()",
          "useRemainingItems(orderId)",
          "useCreateInvoiceFromOrder()",
          "useCreateOrderFromRemaining()",
          "useOrderInvoices(orderId)"
        ]
      },
      {
        "step": 8,
        "name": "UI/UX DETAYLARI",
        "requirements": [
          "Loading states (skeleton loaders)",
          "Error handling (toast notifications)",
          "Confirmation dialogs (silme, iptal)",
          "Success messages",
          "Responsive design (mobile uyumlu)",
          "Accessibility (ARIA labels)"
        ],
        "form_validations": [
          "Miktar > 0",
          "Birim fiyat > 0",
          "Tedarikçi seçilmeli",
          "En az 1 ürün olmalı",
          "Faturada teslim miktarı <= sipariş miktarı"
        ]
      },
      {
        "step": 9,
        "name": "ÖZEL İŞ KURALLARI",
        "rules": [
          "Fatura oluşturulunca purchaseOrderItem.receivedQuantity artır",
          "Item'ın receivedQuantity >= orderedQuantity ise item.status = COMPLETED",
          "Tüm item'lar COMPLETED ise order.status = COMPLETED",
          "Bazı item'lar COMPLETED, bazıları değilse order.status = PARTIAL",
          "COMPLETED veya CANCELLED siparişler düzenlenemez",
          "Sipariş silinince ilişkili faturalar silinmez (soft reference)",
          "Sipariş numarası formatı: PO-{YEAR}-{INCREMENT} (örn: PO-2025-00001)"
        ]
      },
      {
        "step": 10,
        "name": "TEST SENARYOLARI",
        "scenarios": [
          "✅ 10 adet sipariş → 10 adet fatura → sipariş COMPLETED",
          "✅ 10 adet sipariş → 5 adet fatura → sipariş PARTIAL (kalan 5)",
          "✅ Kalan 5 adet için yeni sipariş (farklı tedarikçi) → yeni fatura → her iki sipariş COMPLETED",
          "✅ Sipariş filtreleme (durum, tedarikçi, tarih)",
          "✅ PARTIAL sipariş için 'Kalan Miktarlar' görünümü",
          "✅ Bir siparişten birden fazla fatura oluşturma",
          "✅ PENDING siparişi düzenleme",
          "✅ COMPLETED siparişi düzenlemeye çalışma (engellenmeli)",
          "✅ Sipariş silme ve fatura ilişkisi kontrolü"
        ]
      }
    ],
    "deliverables": [
      "Çalışan Prisma migration dosyaları",
      "Tam NestJS modülü (controller, service, DTOs)",
      "Tam Next.js sayfaları ve component'ler",
      "Zustand store ve TanStack Query hooks",
      "MEVCUT Satın Alma Faturası arayüzü ile entegrasyon",
      "Her adımda kod ve açıklama"
    ],
    "execution_order": [
      "1. Mevcut fatura modülünü analiz et ve raporla",
      "2. Backend (Prisma + NestJS)",
      "3. Frontend (sayfalar + component'ler)",
      "4. Entegrasyon (fatura arayüzü ile)",
      "5. Test ve düzeltmeler"
    ],
    "final_instruction": "Şimdi başla ve her adımı sırayla tamamla. Her adımda ilerlemeni ve karşılaştığın sorunları raporla. MEVCUT Satın Alma Faturası arayüzünü BİREBİR kullanmayı unutma!"
  }
}