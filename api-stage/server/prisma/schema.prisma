  CUSTOMER_DOCUMENT_EXIT
  OWN_DOCUMENT_ENTRY
  OWN_DOCUMENT_EXIT
  BANK_COLLECTION_ENDORSEMENT
  BANK_GUARANTEE_ENDORSEMENT
  ACCOUNT_DOCUMENT_ENDORSEMENT
  DEBIT_DOCUMENT_EXIT
  RETURN_PAYROLL
}

