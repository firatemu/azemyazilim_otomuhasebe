  @@index([employeeId])
  @@map("asset_assignments")
}

model PerformanceReview {
  id             String            @id @default(uuid())
  tenantId       String            @map("tenant_id")
  employeeId     String            @map("employee_id")
  reviewerId     String            @map("reviewer_id")
  periodStart    DateTime          @map("period_start")
  periodEnd      DateTime          @map("period_end")
  overallScore   Decimal?          @map("overall_score") @db.Decimal(3, 1)
  goals          Json?
  strengths      String?
  improvements   String?
  managerNotes   String?           @map("manager_notes")
  status         PerformanceStatus @default(DRAFT)
  submittedAt    DateTime?         @map("submitted_at")
  acknowledgedAt DateTime?         @map("acknowledged_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer       User              @relation("PerformanceReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([employeeId])
  @@index([periodStart, periodEnd])
  @@map("performance_reviews")
}

// ============================================================
// PHASE 8 — Servis Modülü Geliştirmeleri
// ============================================================

enum MaintenanceType {
  PERIODIC
  PREVENTIVE
  PREDICTIVE
  CORRECTIVE
}

model ServiceTemplate {
  id             String      @id @default(uuid())
  tenantId       String      @map("tenant_id")
  name           String
  description    String?
  estimatedHours Decimal?    @map("estimated_hours") @db.Decimal(6, 2)
  laborCost      Decimal?    @map("labor_cost") @db.Decimal(12, 2)
  isActive       Boolean     @default(true) @map("is_active")
  items          Json?
  createdBy      String?     @map("created_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdUser    User?       @relation("ServiceTemplateCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  workOrders     WorkOrder[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("service_templates")
}

model WorkOrderWarranty {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  workOrderId  String    @map("work_order_id")
  warrantyType String    @default("LABOR") @map("warranty_type")
  validUntil   DateTime  @map("valid_until")
  mileageLimit Int?      @map("mileage_limit")
  description  String?
  terms        String?
  isActive     Boolean   @default(true) @map("is_active")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdUser  User?     @relation("WorkOrderWarrantyCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([workOrderId])
  @@index([validUntil])
  @@map("work_order_warranties")
}

model PreventiveMaintenance {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  vehicleId         String?          @map("vehicle_id")
  customerVehicleId String?          @map("customer_vehicle_id")
  maintenanceType   MaintenanceType  @map("maintenance_type")
  name              String
  description       String?
  intervalDays      Int?             @map("interval_days")
  intervalMileage   Int?             @map("interval_mileage")
  lastPerformedAt   DateTime?        @map("last_performed_at")
  lastMileage       Int?             @map("last_mileage")
  nextDueAt         DateTime?        @map("next_due_at")
  nextMileage       Int?             @map("next_mileage")
  isActive          Boolean          @default(true) @map("is_active")
  createdBy         String?          @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyVehicle    CompanyVehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  customerVehicle   CustomerVehicle? @relation(fields: [customerVehicleId], references: [id], onDelete: SetNull)
  createdUser       User?            @relation("PreventiveMaintenanceCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([vehicleId])
  @@index([nextDueAt])
  @@map("preventive_maintenances")
}

model TechnicianMetric {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  technicianId         String   @map("technician_id")
  periodStart          DateTime @map("period_start")
  periodEnd            DateTime @map("period_end")
  totalWorkOrders      Int      @default(0) @map("total_work_orders")
  completedWorkOrders  Int      @default(0) @map("completed_work_orders")
  avgCompletionHours   Decimal  @default(0) @map("avg_completion_hours") @db.Decimal(8, 2)
  reworkCount          Int      @default(0) @map("rework_count")
  customerSatisfaction Decimal? @map("customer_satisfaction") @db.Decimal(3, 1)
  revenueGenerated     Decimal  @default(0) @map("revenue_generated") @db.Decimal(14, 2)
  partsEfficiency      Decimal? @map("parts_efficiency") @db.Decimal(5, 2)
  onTimeDeliveryRate   Decimal? @map("on_time_delivery_rate") @db.Decimal(5, 2)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  technician           User     @relation("TechnicianMetricUser", fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([technicianId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([technicianId])
  @@map("technician_metrics")
}

// ========== B2B Portal (tenant-scoped, main SaaS database) ==========

model B2BLicense {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  isActive        Boolean   @default(true)
  maxB2BCustomers Int       @default(-1)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("b2b_licenses")
}

model B2BTenantConfig {
  id                  String               @id @default(cuid())
  tenantId            String               @unique
  schemaName          String               @unique
  domain              String?              @unique
  erpAdapterType      B2BErpAdapter
  erpConnectionString String?
  lastSyncedAt        DateTime?
  syncIntervalMinutes Int                  @default(60)
  orderApprovalMode   B2BOrderApprovalMode @default(MANUAL)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("b2b_tenant_configs")
}

model B2BDomain {
  id         String   @id @default(cuid())
  domain     String   @unique
  tenantId   String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("b2b_domains")
}

model B2BProduct {
  id               String         @id @default(cuid())
  tenantId         String
  erpProductId     String
  stockCode        String
  name             String
  description      String?
  brand            String?
  category         String?
  oemCode          String?
  supplierCode     String?
  unit             String?
  erpListPrice     Decimal        @db.Decimal(12, 2)
  erpCreatedAt     DateTime?
  erpUpdatedAt     DateTime?
  isVisibleInB2B   Boolean        @default(true)
  minOrderQuantity Int            @default(1)
  imageUrl         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stocks           B2BStock[]
  cartItems        B2BCartItem[]
  orderItems       B2BOrderItem[]

  @@unique([tenantId, erpProductId])
  @@unique([tenantId, stockCode])
  @@index([tenantId, isVisibleInB2B])
  @@map("b2b_products")
}

model B2BStock {
  id            String     @id @default(cuid())
  tenantId      String
  productId     String
  warehouseId   String
  warehouseName String
  isAvailable   Boolean    @default(true)
  displayOrder  Int        @default(0)
  updatedAt     DateTime   @updatedAt
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       B2BProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId, productId])
  @@map("b2b_stocks")
}

model B2BWarehouseConfig {
  id            String                  @id @default(cuid())
  tenantId      String
  warehouseId   String
  warehouseName String
  displayMode   B2BWarehouseDisplayMode @default(INDIVIDUAL)
  isActive      Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, warehouseId])
  @@index([tenantId])
  @@map("b2b_warehouse_configs")
}

model B2BCustomerClass {
  id           String        @id @default(cuid())
  tenantId     String
  name         String
  discountRate Decimal       @default(0) @db.Decimal(5, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers    B2BCustomer[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("b2b_customer_classes")
}

model B2BCustomer {
  id              String    @id @default(cuid())
  tenantId        String
  erpNum          Int?
  erpAccountId    String
  name            String
  email           String
  passwordHash    String
  isActive        Boolean   @default(true)
  customerClassId String?
  vatDays         Int       @default(30)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?

  city             String?
  district         String?
  canUseVirtualPos Boolean @default(true)
  blockOrderOnRisk Boolean @default(false)
  customerGrade    String?
  discountGroupId  String?

  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerClass    B2BCustomerClass?        @relation(fields: [customerClassId], references: [id], onDelete: SetNull)
  discountGroup    B2BDiscount?             @relation(fields: [discountGroupId], references: [id], onDelete: SetNull)
  salespersonLinks B2BSalespersonCustomer[]
  carts            B2BCart[]
  orders           B2BOrder[]
  notifications    B2BNotification[]
  accountMovements B2BAccountMovement[]

  @@unique([tenantId, email])
  @@unique([tenantId, erpAccountId])
  @@index([tenantId, isActive])
  @@map("b2b_customers")
}

model B2BSalesperson {
  id                  String                   @id @default(cuid())
  tenantId            String
  name                String
  email               String
  passwordHash        String
  isActive            Boolean                  @default(true)
  canViewAllCustomers Boolean                  @default(false)
  canViewAllReports   Boolean                  @default(false)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerAssignments B2BSalespersonCustomer[]
  orders              B2BOrder[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@map("b2b_salespersons")
}

model B2BSalespersonCustomer {
  salespersonId String
  customerId    String
  assignedAt    DateTime       @default(now())
  salesperson   B2BSalesperson @relation(fields: [salespersonId], references: [id], onDelete: Cascade)
  customer      B2BCustomer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([salespersonId, customerId])
  @@map("b2b_salesperson_customers")
}

model B2BDiscount {
  id           String          @id @default(cuid())
  tenantId     String
  name         String
  type         B2BDiscountType
  targetValue  String
  discountRate Decimal         @db.Decimal(5, 2)
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers    B2BCustomer[]

  @@index([tenantId, isActive])
  @@map("b2b_discounts")
}

model B2BCart {
  id         String        @id @default(cuid())
  tenantId   String
  customerId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   B2BCustomer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      B2BCartItem[]

  @@unique([tenantId, customerId])
  @@index([tenantId])
  @@map("b2b_carts")
}

model B2BCartItem {
  id        String     @id @default(cuid())
  tenantId  String
  cartId    String
  productId String
  quantity  Int
  addedAt   DateTime   @default(now())
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cart      B2BCart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   B2BProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([tenantId])
  @@map("b2b_cart_items")
}

model B2BDeliveryMethod {
  id           String     @id @default(cuid())
  tenantId     String
  name         String
  isActive     Boolean    @default(true)
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders       B2BOrder[]

  @@index([tenantId, isActive])
  @@map("b2b_delivery_methods")
}

model B2BOrder {
  id                  String            @id @default(cuid())
  tenantId            String
  orderNumber         String
  customerId          String
  salespersonId       String?
  placedBy            B2BOrderPlacedBy
  placedByLabel       String?
  status              B2BOrderStatus    @default(PENDING)
  deliveryBranchId    String?
  deliveryBranchName  String?
  deliveryMethodId    String
  note                String?
  totalListPrice      Decimal           @db.Decimal(14, 2)
  totalDiscountAmount Decimal           @db.Decimal(14, 2)
  totalFinalPrice     Decimal           @db.Decimal(14, 2)
  erpOrderId          String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer            B2BCustomer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesperson         B2BSalesperson?   @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  deliveryMethod      B2BDeliveryMethod @relation(fields: [deliveryMethodId], references: [id])
  items               B2BOrderItem[]
  notifications       B2BNotification[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@map("b2b_orders")
}

model B2BOrderItem {
  id                    String     @id @default(cuid())
  tenantId              String
  orderId               String
  productId             String
  stockCode             String
  productName           String
  quantity              Int
  listPrice             Decimal    @db.Decimal(12, 2)
  customerClassDiscount Decimal    @default(0) @db.Decimal(12, 2)
  campaignDiscount      Decimal    @default(0) @db.Decimal(12, 2)
  finalPrice            Decimal    @db.Decimal(12, 2)
  createdAt             DateTime   @default(now())
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order                 B2BOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               B2BProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId, orderId])
  @@map("b2b_order_items")
}

model B2BNotification {
  id         String              @id @default(cuid())
  tenantId   String
  customerId String
  type       B2BNotificationType
  message    String
  isRead     Boolean             @default(false)
  orderId    String?
  createdAt  DateTime            @default(now())
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   B2BCustomer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order      B2BOrder?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId, customerId])
  @@map("b2b_notifications")
}

model B2BAdvertisement {
  id           String    @id @default(cuid())
  tenantId     String
  type         B2BAdType
  imageUrl     String
  linkUrl      String?
  displayOrder Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, displayOrder])
  @@map("b2b_advertisements")
}

model B2BAccountMovement {
  id            String          @id @default(cuid())
  tenantId      String
  erpMovementId String
  customerId    String
  date          DateTime
  type          B2BMovementType
  description   String?
  debit         Decimal         @default(0) @db.Decimal(12, 2)
  credit        Decimal         @default(0) @db.Decimal(12, 2)
  balance       Decimal         @db.Decimal(12, 2)
  erpInvoiceNo  String?
  dueDate       DateTime?
  isPastDue     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      B2BCustomer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, erpMovementId])
  @@index([tenantId, customerId])
  @@index([tenantId, date])
  @@map("b2b_account_movements")
}

model B2BSyncLog {
  id               String        @id @default(cuid())
  tenantId         String
  syncType         B2BSyncType
  status           B2BSyncStatus
  startedAt        DateTime      @default(now())
  finishedAt       DateTime?
  recordsProcessed Int           @default(0)
  recordsAdded     Int           @default(0)
  recordsUpdated   Int           @default(0)
  errorMessage     String?
  createdAt        DateTime      @default(now())
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, syncType, status, startedAt])
  @@map("b2b_sync_logs")
}

enum B2BOrderApprovalMode {
  MANUAL
  AUTO
}

enum B2BErpAdapter {
  OTOMUHASEBE
  LOGO
  MIKRO
}

enum B2BOrderStatus {
  PENDING
  APPROVED
  REJECTED
  EXPORTED_TO_ERP
  CANCELLED
}

enum B2BOrderPlacedBy {
  CUSTOMER
  SALESPERSON
}

enum B2BNotificationType {
  ORDER_RECEIVED
  ORDER_APPROVED
  ORDER_REJECTED
}

enum B2BAdType {
  HOMEPAGE_BANNER
  LOGIN_POPUP
}

enum B2BMovementType {
  INVOICE
  PAYMENT
  RETURN
  OTHER
}

enum B2BSyncType {
  PRODUCTS
  STOCK
  ACCOUNT_MOVEMENTS
  FULL
}

enum B2BSyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum B2BWarehouseDisplayMode {
  INDIVIDUAL
  COMBINED
}

enum B2BDiscountType {
  CUSTOMER_CLASS
  BRAND
  CATEGORY
  PRODUCT_LIST
}
