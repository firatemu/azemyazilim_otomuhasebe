  logs                   InvoiceLog[]
  invoiceCollections     InvoiceCollection[]
  paymentPlans           InvoicePaymentPlan[]
  account                Account               @relation(fields: [accountId], references: [id])
  createdByUser          User?                 @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])
  deletedByUser          User?                 @relation("InvoiceDeletedBy", fields: [deletedBy], references: [id])
  deliveryNote           SalesDeliveryNote?    @relation("SalesDeliveryNoteInvoice", fields: [deliveryNoteId], references: [id])
  purchaseOrder          PurchaseOrder?        @relation("PurchaseOrderInvoice", fields: [purchaseOrderId], references: [id])
  purchaseDeliveryNote   PurchaseDeliveryNote? @relation("PurchaseDeliveryNoteInvoice", fields: [purchaseDeliveryNoteId], references: [id])
  procurementOrder       ProcurementOrder?     @relation("ProcurementOrderInvoice", fields: [procurementOrderId], references: [id])
  tenant                 Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser          User?                 @relation("InvoiceUpdatedBy", fields: [updatedBy], references: [id])
  invoiceProfits         InvoiceProfit[]
  collections            Collection[]
  posPayments            PosPayment[]
  salesAgentId           String?               @map("sales_agent_id")
  salesAgent             SalesAgent?           @relation(fields: [salesAgentId], references: [id])
  warehouseId            String?               @map("warehouse_id")
  warehouse              Warehouse?            @relation(fields: [warehouseId], references: [id])

  // Opposite relations
  einvoiceSends          EInvoiceSend?
  matchedEInvoiceInboxes EInvoiceInbox[]   @relation("EInvoiceInboxMatchedInvoice")
  accountMovements       AccountMovement[]

  @@unique([invoiceNo, tenantId])
  @@index([tenantId])
  @@index([tenantId, invoiceType])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@index([accountId])
  @@index([status])
  @@index([deliveryNoteId])
  @@index([warehouseId])
  @@index([tenantId, accountId, status])
  @@index([tenantId, date, status])
  @@map("invoices")
}

