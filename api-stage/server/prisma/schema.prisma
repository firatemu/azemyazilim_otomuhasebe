  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  tenantId    String?

  @@unique([warehouseId, locationId, productId])
  @@index([warehouseId])
  @@index([locationId])
  @@index([productId])
  @@index([tenantId])
  @@map("product_location_stocks")
}

model StockMove {
  id              String        @id @default(uuid())
  productId       String        @map("productId")
  fromWarehouseId String?       @map("fromWarehouseId")
  fromLocationId  String?       @map("fromLocationId")
  toWarehouseId   String        @map("toWarehouseId")
  toLocationId    String        @map("toLocationId")
  quantity        Decimal       @map("qty") @db.Decimal(18, 5)
  moveType        StockMoveType @map("moveType")
  refType         String?       @map("refType")
  refId           String?       @map("refId")
  notes           String?       @map("note")
  createdAt       DateTime      @default(now())
  createdBy       String?       @map("createdBy")
  createdByUser   User?         @relation("StockMoveCreatedBy", fields: [createdBy], references: [id])
  fromLocation    Location?     @relation("FromLocation", fields: [fromLocationId], references: [id])
  fromWarehouse   Warehouse?    @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  toLocation      Location      @relation("ToLocation", fields: [toLocationId], references: [id])
  toWarehouse     Warehouse     @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  tenantId        String?

  @@index([productId])
  @@index([fromWarehouseId, fromLocationId])
  @@index([toWarehouseId, toLocationId])
  @@index([moveType])
  @@index([createdAt])
  @@index([refType, refId])
  @@index([tenantId])
  @@map("stock_moves")
}

model ExpenseCategory {
