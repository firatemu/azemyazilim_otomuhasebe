  @@index([tenantId, code])
  @@index([managerId])
  @@map("warehouses")
}

// ========== Faz 4 — Envanter & Depo İyileştirmeleri ==========

enum CostingMethod {
  WEIGHTED_AVERAGE
  FIFO
  LIFO
  FEFO
  STANDARD_COST
}

model WarehouseStockThreshold {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  warehouseId String    @map("warehouse_id")
  productId   String    @map("product_id")
  minQty      Int       @default(0) @map("min_qty")
  maxQty      Int?      @map("max_qty")
  reorderQty  Int?      @map("reorder_qty")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, warehouseId, productId])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_stock_thresholds")
}

model ProductCostingConfig {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  productId     String        @unique @map("product_id")
