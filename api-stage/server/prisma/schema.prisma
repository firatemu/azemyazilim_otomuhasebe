  employee     Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assigner     User?          @relation("AssetAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)
  returner     User?          @relation("AssetReturnedBy", fields: [returnedBy], references: [id], onDelete: SetNull)

