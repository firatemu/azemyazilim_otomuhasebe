}

model Location {
  id                         String                  @id @default(uuid())
  warehouseId                String
  layer                      Int
  corridor                   String
  side                       Int
  section                    Int
  level                      Int
  code                       String                  @unique
  barcode                    String                  @unique
  name                       String?
  active                     Boolean                 @default(true)
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  warehouse                  Warehouse               @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productLocationStocks      ProductLocationStock[]
  stocktakeItems             StocktakeItem[]
  orderPickings              OrderPicking[]          @relation("OrderPickingLocation")
  stockMoves                 StockMove[]             @relation("FromLocation")
  stockMoves2                StockMove[]             @relation("ToLocation")
  fromWarehouseTransferItems WarehouseTransferItem[] @relation("WarehouseTransferItemFrom")
  toWarehouseTransferItems   WarehouseTransferItem[] @relation("WarehouseTransferItemTo")
  // Placeholder for deleted relation
  tenantId                   String?

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([code])
  @@index([barcode])
  @@index([tenantId])
  @@map("locations")
}

model ProductBarcode {
