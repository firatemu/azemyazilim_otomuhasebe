model Warehouse {
  id                      String                    @id @default(uuid())
  code                    String
  tenantId                String?
  name                    String
  active                  Boolean                   @default(true)
  address                 String?
  phone                   String?
  manager                 String? // @deprecated — managerId FK kullan
  managerId               String?                   @map("manager_id")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  isDefault               Boolean                   @default(false)
  locations               Location[]
  productLocationStocks   ProductLocationStock[]
  purchaseDeliveryNotes   PurchaseDeliveryNote[]    @relation("PurchaseDeliveryNoteWarehouse")
  salesDeliveryNotes      SalesDeliveryNote[]       @relation("SalesDeliveryNoteWarehouse")
  productMovementsTo      StockMove[]               @relation("ToWarehouse")
  productMovementsFrom    StockMove[]               @relation("FromWarehouse")
  warehouseCriticalStocks WarehouseCriticalStock[]
  shelves                 Shelf[]
  fromWarehouseTransfers  WarehouseTransfer[]       @relation("WarehouseTransferFrom")
  toWarehouseTransfers    WarehouseTransfer[]       @relation("WarehouseTransferTo")
  invoices                Invoice[]
  inventoryTransactions   InventoryTransaction[]
  tenant                  Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productMovements        ProductMovement[]         @relation("WarehouseProductMovement")
