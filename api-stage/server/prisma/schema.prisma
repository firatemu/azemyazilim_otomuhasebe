  partWorkflowStatus      PartWorkflowStatus    @default(NOT_STARTED) @map("partWorkflowStatus")
  vehicleWorkflowStatus   VehicleWorkflowStatus @default(WAITING) @map("vehicleWorkflowStatus")
  customerVehicleId       String                @map("customerVehicleId")
  accountId               String                @map("account_id")
  technicianId            String?               @map("technicianId")
  description             String?               @map("description")
  diagnosisNotes          String?               @map("diagnosisNotes")
  supplyResponseNotes     String?               @map("supplyResponseNotes")
  estimatedCompletionDate DateTime?             @map("estimatedCompletionDate")
  actualCompletionDate    DateTime?             @map("actualCompletionDate")
  totalLaborCost          Decimal               @default(0) @map("totalLaborCost") @db.Decimal(12, 2)
  totalPartsCost          Decimal               @default(0) @map("totalPartsCost") @db.Decimal(12, 2)
  taxAmount               Decimal               @default(0) @map("taxAmount") @db.Decimal(12, 2)
  grandTotal              Decimal               @default(0) @map("grandTotal") @db.Decimal(12, 2)
  version                 Int                   @default(1) @map("version")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  deletedAt               DateTime?             @map("deleted_at")
  deletedBy               String?               @map("deleted_by")
  updatedBy               String?               @map("updated_by")
  deletedByUser           User?                 @relation("WorkOrderDeletedBy", fields: [deletedBy], references: [id])
  updatedByUser           User?                 @relation("WorkOrderUpdatedBy", fields: [updatedBy], references: [id])
  account                 Account               @relation(fields: [accountId], references: [id])
  customerVehicle         CustomerVehicle       @relation(fields: [customerVehicleId], references: [id], onDelete: Cascade)
  items                   WorkOrderItem[]
  partRequests            PartRequest[]
  serviceInvoice          ServiceInvoice?
  technician              User?                 @relation("WorkOrderTechnician", fields: [technicianId], references: [id])
  tenant                  Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
