  updatedAt   DateTime @updatedAt

  journal   CheckBillJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  checkBill CheckBill        @relation(fields: [checkBillId], references: [id], onDelete: Cascade)
  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([journalId])
  @@index([checkBillId])
  @@index([tenantId])
  @@map("check_bill_journal_items")
}

model CheckBill {
  id                  String                 @id @default(uuid())
  tenantId            String?
  type                CheckBillType          @map("type")
  portfolioType       PortfolioType          @map("portfolio_type")
  accountId           String                 @map("account_id")
  amount              Decimal                @map("amount") @db.Decimal(15, 2)
  remainingAmount     Decimal                @default(0) @map("remaining_amount") @db.Decimal(15, 2)
  dueDate             DateTime               @map("due_date")
  bank                String?                @map("bank")
  branch              String?                @map("branch")
  accountNo           String?                @map("account_no")
  checkNo             String?                @map("check_no")
  serialNo            String?                @map("serial_no")
  status              CheckBillStatus?       @map("status")
  collectionDate      DateTime?              @map("collection_date")
  collectionCashboxId String?                @map("collection_cashbox_id")
  isEndorsed          Boolean                @default(false) @map("is_endorsed")
  endorsementDate     DateTime?              @map("endorsement_date")
  endorsedTo          String?                @map("endorsed_to")
  notes               String?                @map("notes")
  createdBy           String?                @map("created_by")
  updatedBy           String?                @map("updated_by")
  deletedAt           DateTime?              @map("deleted_at")
  deletedBy           String?                @map("deleted_by")
  currentHolderId     String?                @map("current_holder_id")
  isProtested         Boolean                @default(false) @map("is_protested")
  protestedAt         DateTime?              @map("protested_at")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  logs                CheckBillLog[]
  account             Account                @relation(fields: [accountId], references: [id])
  createdByUser       User?                  @relation("CheckBillCreatedBy", fields: [createdBy], references: [id])
  deletedByUser       User?                  @relation("CheckBillDeletedBy", fields: [deletedBy], references: [id])
  collectionCashbox   Cashbox?               @relation(fields: [collectionCashboxId], references: [id])
  tenant              Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser       User?                  @relation("CheckBillUpdatedBy", fields: [updatedBy], references: [id])
  lastJournalId       String?                @map("last_journal_id")
  lastJournal         CheckBillJournal?      @relation("CheckBillLastJournal", fields: [lastJournalId], references: [id])
  journalItems        CheckBillJournalItem[]
  currentHolder       Account?               @relation("CheckBillCurrentHolder", fields: [currentHolderId], references: [id])
  endorsements        CheckBillEndorsement[]
  accountMovements    AccountMovement[]
  collections         CheckBillCollection[]

  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@index([accountId])
  @@index([dueDate])
  @@index([status])
  @@index([type])
  @@index([portfolioType])
  @@map("checks_bills")
}

model DeletedCheckBill {
