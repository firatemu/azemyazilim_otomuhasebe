  CUSTOMER_APPROVAL_PENDING
  IN_PROGRESS
  PART_WAITING
  PARTS_SUPPLIED
  VEHICLE_READY
  COMPLETED
}

model CustomerVehicle {
  id                    String                  @id @default(uuid())
  tenantId              String?                 @map("tenantId")
  accountId             String                  @map("account_id")
