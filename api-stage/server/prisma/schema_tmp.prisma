// Maaş Planı - Her personel için 12 aylık plan
model SalaryPlan {
  id              String             @id @default(uuid())
  tenantId        String?
  employeeId      String             @map("employee_id")
  year            Int                @map("year")
  month           Int                @map("month")
  salary          Decimal            @db.Decimal(10, 2) @map("salary")
  bonus           Decimal            @default(0) @db.Decimal(10, 2) @map("bonus")
  total           Decimal            @db.Decimal(10, 2) @map("total")
  status          SalaryStatus       @default(ODENMEDI) @map("status")
  paidAmount      Decimal            @default(0) @db.Decimal(10, 2) @map("paid_amount")
  remainingAmount Decimal            @db.Decimal(10, 2) @map("remaining_amount")
  isActive        Boolean            @default(true) @map("is_active")
  description     String?            @map("description")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payments        SalaryPayment[]
  settlements     AdvanceSettlement[]

  @@unique([employeeId, year, month])
  @@index([tenantId])
  @@index([employeeId, year])
  @@index([status])
  @@index([year, month])
  @@map("salary_plans")
}

enum SalaryStatus {
  ODENMEDI
  KISMI_ODENDI
  TAMAMEN_ODENDI
}

// Maaş Ödeme - Bir plana ait ödemeler (parçalı ödeme desteği)
model SalaryPayment {
  id              String             @id @default(uuid())
  tenantId        String?
  salaryPlanId    String             @map("plan_id")
  employeeId      String             @map("personel_id")
  amount          Decimal            @db.Decimal(10, 2) @map("amount")
  date            DateTime           @default(now()) @map("date")
  description     String?            @map("aciklama")
  createdBy       String?            @map("created_by")
  createdAt       DateTime           @default(now())

  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryPlan      SalaryPlan         @relation(fields: [salaryPlanId], references: [id], onDelete: Cascade)
  employee        Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  paymentDetails  SalaryPaymentDetail[]
  createdByUser   User?              @relation("SalaryPaymentCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([salaryPlanId])
  @@index([employeeId])
  @@index([date])
  @@map("salary_payments")
}

// Maaş Ödeme Detay - Çoklu ödeme yöntemi desteği
model SalaryPaymentDetail {
  id              String             @id @default(uuid())
  tenantId        String?
  salaryPaymentId String             @map("odeme_id")
  paymentMethod   PaymentMethod      @map("odeme_tipi")
  amount          Decimal            @db.Decimal(10, 2) @map("amount")
  cashboxId       String?            @map("kasa_id")
  bankAccountId   String?            @map("banka_hesap_id")
  referenceNo     String?            @map("referans_no")
  description     String?            @map("aciklama")
  createdAt       DateTime           @default(now())

  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryPayment   SalaryPayment      @relation(fields: [salaryPaymentId], references: [id], onDelete: Cascade)
  cashbox         Cashbox?           @relation(fields: [cashboxId], references: [id])
  bankAccount     BankAccount?       @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([salaryPaymentId])
  @@index([cashboxId])
  @@index([bankAccountId])
  @@map("salary_payment_details")
}

// Avans Sistemi
model Advance {
  id              String             @id @default(uuid())
  tenantId        String?
  employeeId      String             @map("personel_id")
  amount          Decimal            @db.Decimal(10, 2) @map("amount")
  date            DateTime           @default(now()) @map("date")
  description     String?            @map("aciklama")
  cashboxId       String?            @map("cashbox_id")
  settledAmount   Decimal            @default(0) @db.Decimal(10, 2) @map("mahsup_edilen")
  remainingAmount Decimal            @db.Decimal(10, 2) @map("kalan")
  status          AdvanceStatus      @default(ACIK) @map("status")
  createdBy       String?            @map("created_by")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cashbox         Cashbox?           @relation(fields: [cashboxId], references: [id])
  settlements     AdvanceSettlement[]
  createdByUser   User?              @relation("AdvanceCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@index([date])
  @@index([cashboxId])
  @@map("advances")
}

enum AvansDurum {
