generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  INDIVIDUAL
  CORPORATE
}

model Tenant {
  id                     String                       @id @default(cuid())
  uuid                   String                       @unique @default(uuid())
  name                   String
  subdomain              String?                      @unique
  domain                 String?                      @unique
  status                 TenantStatus                 @default(TRIAL)
  cancelledAt            DateTime?
  purgedAt               DateTime?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  auditLogs              AuditLog[]
  bankTransfers          BankTransfer[]
  unitSets               UnitSet[]
  simpleOrders           SimpleOrder[]
  accounts               Account[]
  checksBills            CheckBill[]
  invoices               Invoice[]
  invitations            Invitation[]
  invoiceProfits         InvoiceProfit[]
  cashboxes              Cashbox[]
  expenses               Expense[]
  employees              Employee[]
  purchaseOrders         PurchaseOrder[]
  purchaseDeliveryNotes  PurchaseDeliveryNote[]       @relation("PurchaseDeliveryNoteTenant")
  procurementOrders      ProcurementOrder[]
  salesDeliveryNotes     SalesDeliveryNote[]          @relation("SalesDeliveryNoteTenant")
  stocktakes             Stocktake[]
  salesOrders            SalesOrder[]
  products               Product[]
  subscription           Subscription?
  systemParameters       SystemParameter[]
  collections            Collection[]
  quotes                 Quote[]
  settings               TenantSettings?
  users                  User[]
  warehouseTransfers     WarehouseTransfer[]
  warehouses             Warehouse[]
  banks                  Bank[]
  checkBillJournals      CheckBillJournal[]
  salesAgents            SalesAgent[]
  salaryPlans            SalaryPlan[]
  salaryPayments         SalaryPayment[]
  salaryPaymentDetails   SalaryPaymentDetail[]
  advances               Advance[]
  advanceSettlements     AdvanceSettlement[]
  accountMovements       AccountMovement[]
  productMovements       ProductMovement[]
  invoiceCollections     InvoiceCollection[]
  roles                  Role[]
  tenantPurgeAudits      TenantPurgeAudit[]
  codeTemplates          CodeTemplate[]
  tenantType             TenantType                   @default(CORPORATE)
  customerVehicles       CustomerVehicle[]
  workOrders             WorkOrder[]
  partRequests           PartRequest[]
  inventoryTransactions  InventoryTransaction[]
  checkBillJournalItems  CheckBillJournalItem[]
  journalEntries         JournalEntry[]
  serviceInvoices        ServiceInvoice[]
  companyVehicles        CompanyVehicle[]
  vehicleExpenses        VehicleExpense[]

  @@index([subdomain])
  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("tenants")
}

model TenantSettings {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  companyName  String?
  taxNumber    String?
  address      String?
  logoUrl      String?
  features     Json?
  limits       Json?
  timezone     String   @default("Europe/Istanbul")
  locale       String   @default("tr-TR")
  currency     String   @default("TRY")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  city         String?
  companyType  String?  @default("COMPANY")
  country      String?
  district     String?
  email        String?
  firstName    String?
  lastName     String?
  mersisNo     String?
  neighborhood String?
  phone        String?
  postalCode   String?
  taxOffice    String?
  tcNo         String?
  website      String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("TRY")
  billingPeriod BillingPeriod  @default(MONTHLY)
  trialDays     Int            @default(0)
  baseUserLimit Int            @default(1)
  features      Json?
  limits        Json?
  isActive      Boolean        @default(true)
  isPopular     Boolean        @default(false)
  isBasePlan    Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive])
  @@index([isBasePlan])
  @@map("plans")
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  planId                String
  status                SubscriptionStatus @default(TRIAL)
  startDate             DateTime           @default(now())
  endDate               DateTime
  trialEndsAt           DateTime?
  canceledAt            DateTime?
  nextBillingDate       DateTime?
  lastBillingDate       DateTime?
  autoRenew             Boolean            @default(true)
  iyzicoSubscriptionRef String?            @unique
  additionalUsers       Int                @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  moduleLicenses        ModuleLicense[]
  payments              Payment[]
  plan                  Plan               @relation(fields: [planId], references: [id])
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("TRY")
  status          PaymentStatus @default(PENDING)
  iyzicoPaymentId String?       @unique
  iyzicoToken     String?       @unique
  conversationId  String?       @unique
  invoiceNumber   String?
  invoiceUrl      String?
  paidAt          DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  paymentMethod   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([iyzicoPaymentId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("payments")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tenantId   String?
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id                             String                    @id @default(uuid())
  uuid                           String                    @unique @default(uuid())
  email                          String
  username                       String
  password                       String
  firstName                      String?
  lastName                       String?
  fullName                       String
  phone                          String?
  avatarUrl                      String?
  role                           UserRole                  @default(USER)
  department                     String?
  status                         UserStatus                @default(ACTIVE)
  isActive                       Boolean                   @default(true)
  refreshToken                   String?
  tokenVersion                   Int                       @default(0)
  tenantId                       String?
  emailVerified                  Boolean                   @default(false)
  lastLoginAt                    DateTime?
  createdAt                      DateTime                  @default(now())
  updatedAt                      DateTime                  @updatedAt
  bankaHavaleLogs                BankaHavaleLog[]
  createdBankaHavaleler          BankaHavale[]             @relation("BankaHavaleCreatedBy")
  deletedBankaHavaleler          BankaHavale[]             @relation("BankaHavaleDeletedBy")
  updatedBankaHavaleler          BankaHavale[]             @relation("BankaHavaleUpdatedBy")
  cekSenetLogs                   CekSenetLog[]
  createdCekSenetler             CekSenet[]                @relation("CekSenetCreatedBy")
  deletedCekSenetler             CekSenet[]                @relation("CekSenetDeletedBy")
  updatedCekSenetler             CekSenet[]                @relation("CekSenetUpdatedBy")
  deletedBankaHavaleRecords      DeletedBankaHavale[]      @relation("DeletedBankaHavaleDeletedBy")
  deletedCekSenetRecords         DeletedCekSenet[]         @relation("DeletedCekSenetDeletedBy")
  faturaLogs                     InvoiceLog[]
  createdInvoicelar               Invoice[]                  @relation("InvoiceCreatedBy")
  deletedInvoicelar               Invoice[]                  @relation("InvoiceDeletedBy")
  updatedInvoicelar               Invoice[]                  @relation("InvoiceUpdatedBy")
  createdCashbox_tmpHareketler          Cashbox_tmpHareket[]             @relation("Cashbox_tmpHareketCreatedBy")
  createdCashbox_tmplar                 Cashbox_tmp[]                    @relation("Cashbox_tmpCreatedBy")
  updatedCashbox_tmplar                 Cashbox_tmp[]                    @relation("Cashbox_tmpUpdatedBy")
  createdEmployeeOdemeler        EmployeeOdeme[]           @relation("EmployeeOdemeCreatedBy")
  createdEmployeeler             Employee[]                @relation("EmployeeCreatedBy")
  updatedEmployeeler             Employee[]                @relation("EmployeeUpdatedBy")
  createdPriceCards              PriceCard[]               @relation("PriceCardCreatedBy")
  updatedPriceCards              PriceCard[]               @relation("PriceCardUpdatedBy")
  createdSatınAlmaIrsaliyeleri  SatınAlmaIrsaliyesi[]    @relation("SatınAlmaIrsaliyesiCreatedBy")
  deletedSatınAlmaIrsaliyeleri  SatınAlmaIrsaliyesi[]    @relation("SatınAlmaIrsaliyesiDeletedBy")
  updatedSatınAlmaIrsaliyeleri  SatınAlmaIrsaliyesi[]    @relation("SatınAlmaIrsaliyesiUpdatedBy")
  satınAlmaIrsaliyesiLogs       SatınAlmaIrsaliyesiLog[] @relation("SatınAlmaIrsaliyesiLogUser")
  satinAlmaSiparisLogs           SatınAlmaSiparisLog[]    @relation("SatınAlmaSiparisLogUser")
  createdSatinAlmaSiparisler     SatınAlmaSiparisi[]      @relation("SatınAlmaSiparisiCreatedBy")
  deletedSatinAlmaSiparisler     SatınAlmaSiparisi[]      @relation("SatınAlmaSiparisiDeletedBy")
  updatedSatinAlmaSiparisler     SatınAlmaSiparisi[]      @relation("SatınAlmaSiparisiUpdatedBy")
  createdSatisIrsaliyeleri       SatisIrsaliyesi[]         @relation("SatisIrsaliyesiCreatedBy")
  deletedSatisIrsaliyeleri       SatisIrsaliyesi[]         @relation("SatisIrsaliyesiDeletedBy")
  updatedSatisIrsaliyeleri       SatisIrsaliyesi[]         @relation("SatisIrsaliyesiUpdatedBy")
  satisIrsaliyesiLogs            SatisIrsaliyesiLog[]      @relation("SatisIrsaliyesiLogUser")
  createdSayimlar                Sayim[]                   @relation("SayimCreatedBy")
  onayladigiSayimlar             Sayim[]                   @relation("SayimOnaylayan")
  updatedSayimlar                Sayim[]                   @relation("SayimUpdatedBy")
  sessions                       Session[]
  siparisHazirliklar             SiparisHazirlik[]         @relation("SiparisHazirlikCreatedBy")
  siparisLogs                    SiparisLog[]
  createdSiparisler              Siparis[]                 @relation("SiparisCreatedBy")
  deletedSiparisler              Siparis[]                 @relation("SiparisDeletedBy")
  updatedSiparisler              Siparis[]                 @relation("SiparisUpdatedBy")
  stockMoves                     StockMove[]               @relation("StockMoveCreatedBy")
  createdCollectionlar             Collection[]                @relation("CollectionCreatedBy")
  deletedCollectionlar             Collection[]                @relation("CollectionDeletedBy")
  teklifLogs                     TeklifLog[]               @relation("TeklifLogUser")
  createdTeklifler               Teklif[]                  @relation("TeklifCreatedBy")
  deletedTeklifler               Teklif[]                  @relation("TeklifDeletedBy")
  updatedTeklifler               Teklif[]                  @relation("TeklifUpdatedBy")
  licenses                       UserLicense[]
  tenant                         Tenant?                   @relation(fields: [tenantId], references: [id])
  warehouseTransferLogs          WarehouseTransferLog[]
  createdWarehouseTransfers      WarehouseTransfer[]       @relation("WarehouseTransferCreatedBy")
  deletedWarehouseTransfers      WarehouseTransfer[]       @relation("WarehouseTransferDeletedBy")
  createdBordrolar               Bordro[]                  @relation("BordroCreatedBy")
  hazirlananWarehouseTransfers   WarehouseTransfer[]       @relation("WarehouseTransferHazirlayan")
  onaylananWarehouseTransfers    WarehouseTransfer[]       @relation("WarehouseTransferOnaylayan")
  teslimAlinanWarehouseTransfers WarehouseTransfer[]       @relation("WarehouseTransferTeslimAlan")
  updatedWarehouseTransfers      WarehouseTransfer[]       @relation("WarehouseTransferUpdatedBy")
  createdAvanslar                Avans[]                   @relation("AvansCreatedBy")
  createdMaasOdemeler            MaasOdeme[]               @relation("MaasOdemeCreatedBy")
  workOrdersAsTechnician          WorkOrder[]              @relation("WorkOrderTechnician")
  workOrderActivities             WorkOrderActivity[]
  partRequestsRequested          PartRequest[]
  createdServiceInvoices         ServiceInvoice[]
  roleId                         String?
  roleRelation                   Role?                     @relation(fields: [roleId], references: [id])

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model Product {
  id                      String                   @id @default(uuid())
  code                    String                   @map("code")
  tenantId                String?
  name                    String                   @map("name")
  description             String?                  @map("description")
  unit                    String                   @map("unit")
  purchasePrice           Decimal                  @db.Decimal(10, 2) @map("purchase_price")
  salePrice               Decimal                  @db.Decimal(10, 2) @map("sale_price")
  vatRate                 Int                      @default(20) @map("vat_rate")
  criticalQty             Int                      @default(0) @map("critical_qty")
  category                String?                  @map("category")
  mainCategory            String?                  @map("main_category")
  subCategory             String?                  @map("sub_category")
  brand                   String?                  @map("brand")
  model                   String?                  @map("model")
  oem                     String?                  @map("oem")
  size                    String?                  @map("size")
  shelf                   String?                  @map("shelf")
  barcode                 String?                  @map("barcode")
  supplierCode            String?                  @map("supplier_code")
  equivalencyGroupId      String?                  @map("equivalency_group_id")
  vehicleBrand            String?                  @map("vehicle_brand")
  vehicleModel            String?                  @map("vehicle_model")
  vehicleEngineSize       String?                  @map("vehicle_engine_size")
  vehicleFuelType         String?                  @map("vehicle_fuel_type")
  isCategoryOnly          Boolean?                 @default(false) @map("is_category_only")
  isBrandOnly             Boolean?                 @default(false) @map("is_brand_only")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  simpleOrders            SimpleOrder[]            @relation("SimpleOrderProduct")
  invoiceItems            InvoiceItem[]
  invoiceProfits          InvoiceProfit[]
  priceCards              PriceCard[]
  productBarcodes         ProductBarcode[]
  productLocationStocks   ProductLocationStock[]
  purchaseOrderItems      PurchaseOrderItem[]      @relation("PurchaseOrderItemProduct")
  purchaseDeliveryNoteItems PurchaseDeliveryNoteItem[] @relation("PurchaseDeliveryNoteItemProduct")
  procurementOrderItems    ProcurementOrderItem[]    @relation("ProcurementOrderItemProduct")
  salesDeliveryNoteItems   SalesDeliveryNoteItem[]   @relation("SalesDeliveryNoteItemProduct")
  stocktakeItems          StocktakeItem[]
  salesOrderItems         SalesOrderItem[]
  costHistory             StockCostHistory[]
  stockMoves              StockMove[]
  equivalents             ProductEquivalent[]      @relation("Product1")
  equivalents2            ProductEquivalent[]      @relation("Product2")
  productMovements        ProductMovement[]
  equivalencyGroup        EquivalencyGroup?        @relation(fields: [equivalencyGroupId], references: [id])
  tenant                  Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteItems              QuoteItem[]
  shelves                 ProductShelf[]
  warehouseCriticalStocks WarehouseCriticalStock[]
  warehouseTransferItems  WarehouseTransferItem[]
  workOrderItems          WorkOrderItem[]
  partRequests            PartRequest[]
  inventoryTransactions   InventoryTransaction[]
  unitId                  String?                  @map("unit_id")
  unitRef                 Unit?                    @relation(fields: [unitId], references: [id])

  @@unique([code, tenantId])
  @@unique([barcode, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
  @@index([tenantId, barcode])
  @@map("products")
}

model PriceCard {
  id            String        @id @default(uuid())
  productId     String        @map("product_id")
  type          PriceCardType
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("TRY")
  effectiveFrom DateTime?     @map("effective_from")
  effectiveTo   DateTime?     @map("effective_to")
  note          String?
  createdBy     String?       @map("created_by")
  updatedBy     String?       @map("updated_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdByUser User?         @relation("PriceCardCreatedBy", fields: [createdBy], references: [id])
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedByUser User?         @relation("PriceCardUpdatedBy", fields: [updatedBy], references: [id])

  @@index([productId, type, createdAt])
  @@map("price_cards")
}

model ProductCostHistory {
  id           String   @id @default(uuid())
  productId     String   @map("product_id")
  cost         Decimal  @db.Decimal(12, 4)
  method       String   @default("WEIGHTED_AVERAGE")
  computedAt   DateTime @default(now()) @map("computed_at")
  brand        String?  @map("brand")
  mainCategory String?  @map("main_category")
  subCategory  String?  @map("sub_category")
  note         String?
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, computedAt])
  @@map("stock_cost_history")
}

model EquivalencyGroup {
  id          String    @id @default(uuid())
  name        String?   @map("name")
  description String?   @map("description")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("equivalency_groups")
}

model ProductEquivalent {
  id        String   @id @default(uuid())
  product1Id String   @map("product1_id")
  product2Id String   @map("product2_id")
  createdAt DateTime @default(now())
  product1  Product  @relation("Product1", fields: [product1Id], references: [id], onDelete: Cascade)
  product2  Product  @relation("Product2", fields: [product2Id], references: [id], onDelete: Cascade)

  @@unique([product1Id, product2Id])
  @@map("product_equivalents")
}

model ProductMovement {
  id             String        @id @default(uuid())
  productId      String        @map("product_id")
  movementType   MovementType   @map("movement_type")
  quantity       Int           @map("quantity")
  unitPrice      Decimal       @db.Decimal(10, 2) @map("unit_price")
  notes          String?       @map("notes")
  createdAt      DateTime      @default(now())
  warehouseId    String?
  invoiceItemId  String?       @map("invoice_item_id")
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?    @relation(fields: [warehouseId], references: [id])
  invoiceItem    InvoiceItem?  @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  tenantId       String?
  tenant         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceItemId])
  @@map("product_movements")
}

model Account {
  id                        String                   @id @default(uuid())
  code                      String                   @map("code")
  tenantId                  String?
  title                     String                   @map("title")
  type                      AccountType                  @map("type")
  companyType               CompanyType?              @default(KURUMSAL) @map("company_type")
  taxNumber                 String?                  @map("tax_number")
  taxOffice                 String?                  @map("tax_office")
  nationalId                String?                  @map("national_id")
  fullName                  String?                  @map("full_name")
  phone                     String?                  @map("phone")
  email                     String?                  @map("email")
  country                   String?                  @default("Türkiye") @map("country")
  city                      String?                  @map("city")
  district                  String?                  @map("district")
  address                   String?                  @map("address")
  contactName               String?                  @map("contact_name")
  balance                   Decimal                  @default(0) @db.Decimal(12, 2) @map("balance")
  paymentTermDays           Int?                     @map("payment_term_days")
  isActive                  Boolean                  @default(true) @map("is_active")
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  bankTransfers             BankTransfer[]
  bankAccountMovements      BankAccountMovement[]
  checkBillJournals         CheckBillJournal[]
  simpleOrders              SimpleOrder[]            @relation("SimpleOrderAccount")
  accountMovements          AccountMovement[]
  tenant                    Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checksBills               CheckBill[]
  invoices                  Invoice[]
  companyCreditCardMovements CompanyCreditCardMovement[]
  cashboxMovements          CashboxMovement[]
  purchaseOrders            PurchaseOrder[]          @relation("PurchaseOrderSupplier")
  purchaseDeliveryNotes     PurchaseDeliveryNote[]   @relation("PurchaseDeliveryNoteAccount")
  procurementOrders         ProcurementOrder[]       @relation("ProcurementOrderAccount")
  salesDeliveryNotes        SalesDeliveryNote[]      @relation("SalesDeliveryNoteAccount")
  salesOrders               SalesOrder[]
  collections               Collection[]
  quotes                    Quote[]
  salesAgentId              String?                  @map("sales_agent_id")
  salesAgent                SalesAgent?              @relation(fields: [salesAgentId], references: [id])

  // Risk Yönetimi
  creditLimit      Decimal?    @db.Decimal(12, 2) @map("credit_limit")
  creditStatus     RiskStatus? @default(NORMAL) @map("credit_status")
  collateralAmount Decimal?    @db.Decimal(12, 2) @map("collateral_amount")

  // Detaylar
  sector         String?       @map("sector")
  customCode1    String?       @map("custom_code1")
  customCode2    String?       @map("custom_code2")
  website        String?       @map("website")
  fax            String?       @map("fax")
  dueDays        Int?          @map("due_days")
  currency       String?       @map("currency")
  bankInfo       String?       @map("bank_info")
  priceListId    String?       @map("price_list_id")
  priceList      PriceList?    @relation(fields: [priceListId], references: [id])

  contacts          AccountContact[]
  addresses         AccountAddress[]
  banks             AccountBank[]
  customerVehicles  CustomerVehicle[]
  workOrders        WorkOrder[]
  serviceInvoices   ServiceInvoice[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
  @@map("accounts")
}

model AccountContact {
  id         String   @id @default(uuid())
  accountId  String   @map("account_id")
  fullName   String   @map("full_name")
  title      String?  @map("title")
  phone      String?  @map("phone")
  email      String?  @map("email")
  extension  String?  @map("extension")
  isDefault  Boolean  @default(false) @map("is_default")
  notes      String?  @map("notes")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("account_contacts")
}

model AccountAddress {
  id         String    @id @default(uuid())
  accountId  String    @map("account_id")
  title      String    @map("title")
  type       AddressType @map("type")
  address    String    @map("address")
  city       String?   @map("city")
  district   String?   @map("district")
  postalCode String?   @map("postal_code")
  isDefault  Boolean   @default(false) @map("is_default")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("account_addresses")
}

model AccountBank {
  id         String   @id @default(uuid())
  accountId  String   @map("account_id")
  bankName   String   @map("bank_name")
  branchName String?  @map("branch_name")
  branchCode String?  @map("branch_code")
  accountNo  String?  @map("account_no")
  iban       String   @map("iban")
  currency   String?  @map("currency")
  notes      String?  @map("notes")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("account_banks")
}

model AccountMovement {
  id           String     @id @default(uuid())
  accountId    String     @map("account_id")
  type         DebitCredit @map("type")
  amount       Decimal    @db.Decimal(12, 2) @map("amount")
  balance      Decimal    @db.Decimal(12, 2) @map("balance")
  documentType DocumentType? @map("document_type")
  documentNo   String?    @map("document_no")
  date         DateTime   @default(now()) @map("date")
  notes        String     @map("notes")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId     String?
