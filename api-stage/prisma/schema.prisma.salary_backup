// ============= DEPO YÖNETİMİ (YENİ - Gelişmiş Raf Sistemi) =============

model Warehouse {
  id        String   @id @default(uuid())
  code      String
  tenantId  String? // Multi-tenant support
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String // Depo adı
  active    Boolean  @default(true)
  address   String? // Adres
  phone     String? // Telefon
  manager   String? // Yetkili
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations             Location[]
  stockMoves            StockMove[]            @relation("FromWarehouse")
  stockMoves2           StockMove[]            @relation("ToWarehouse")
  productLocationStocks ProductLocationStock[]
  satisIrsaliyeleri     SatisIrsaliyesi[]      @relation("SatisIrsaliyesiDepo")
  satınAlmaIrsaliyeleri SatınAlmaIrsaliyesi[]  @relation("SatınAlmaIrsaliyesiDepo")

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
  @@map("warehouses")
}

model Location {
  id          String   @id @default(uuid())
  warehouseId String
  layer       Int // Kat (1..3)
  corridor    String // Koridor (A..T - İlk 20 harf)
  side        Int // Taraf (1=Sol, 2=Sağ)
  section     Int // Bölüm (1..99)
  level       Int // Raf seviyesi (1..50)
  code        String   @unique // Format: K{layer}-{corridor}{side}-{section}-{level} (örn: K1-A1-3-5)
  barcode     String   @unique // Barkod (genelde code ile aynı)
  name        String? // Opsiyonel açıklama
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse             Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockMoves            StockMove[]            @relation("FromLocation")
  stockMoves2           StockMove[]            @relation("ToLocation")
  productLocationStocks ProductLocationStock[]
  siparisHazirliklar    SiparisHazirlik[]
  sayimKalemleri        SayimKalemi[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([code])
  @@index([barcode])
  @@map("locations")
}

model ProductBarcode {
  id        String   @id @default(uuid())
  productId String // Stok ID
  barcode   String   @unique // Barkod değeri
  symbology String // QR, EAN13, Code128, vb.
  isPrimary Boolean  @default(false) // Birincil barkod mu?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Stok @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([barcode])
  @@map("product_barcodes")
}

model ProductLocationStock {
  id          String   @id @default(uuid())
  warehouseId String
  locationId  String
  productId   String // Stok ID
  qtyOnHand   Int      @default(0) // Eldeki miktar (anlık bakiye - denormalize)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location  Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product   Stok      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, locationId, productId])
  @@index([warehouseId])
  @@index([locationId])
  @@index([productId])
  @@map("product_location_stocks")
}

enum StockMoveType {
  PUT_AWAY // Ürünü rafa yerleştirme
  TRANSFER // Raflar arası transfer
  PICKING // Siparişten çıkış
  ADJUSTMENT // Envanter düzeltme
  SALE // Satış
  RETURN // İade
  DAMAGE // Hasarlı ürün çıkışı
}

model StockMove {
  id              String        @id @default(uuid())
  productId       String // Stok ID
  fromWarehouseId String? // Kaynak depo (nullable - put-away için NULL)
  fromLocationId  String? // Kaynak raf (nullable)
  toWarehouseId   String // Hedef depo
  toLocationId    String // Hedef raf
  qty             Int // Miktar (pozitif)
  moveType        StockMoveType // Hareket tipi
  refType         String? // Referans tipi (Order, PutAway, Transfer, vb.)
  refId           String? // Referans ID (işlem referansı)
  note            String? // Açıklama
  createdAt       DateTime      @default(now())
  createdBy       String? // User ID

  product       Stok       @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  fromLocation  Location?  @relation("FromLocation", fields: [fromLocationId], references: [id])
  toWarehouse   Warehouse  @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  toLocation    Location   @relation("ToLocation", fields: [toLocationId], references: [id])
  createdByUser User?      @relation("StockMoveCreatedBy", fields: [createdBy], references: [id])

  @@index([productId])
  @@index([fromWarehouseId, fromLocationId])
  @@index([toWarehouseId, toLocationId])
  @@index([moveType])
  @@index([createdAt])
  @@index([refType, refId])
  @@map("stock_moves")
}

