model PurchaseOrder {
  id                   String      @id @default(uuid())
  orderNumber          String
  tenantId             String? // Multi-tenant support
  tenant               Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId           String      @map("supplier_id")
  orderDate            DateTime    @default(now()) @map("order_date")
  expectedDeliveryDate DateTime?   @map("expected_delivery_date")
  status               OrderStatus @default(PENDING)
  totalAmount          Decimal     @map("total_amount") @db.Decimal(12, 2)
  notes                String?
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  supplier Cari                @relation("PurchaseOrderSupplier", fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  invoices Fatura[]            @relation("PurchaseOrderFatura")

  @@unique([orderNumber, tenantId])
  @@index([tenantId])
  @@index([tenantId, orderNumber])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

// Purchase Order Item
model PurchaseOrderItem {
  id               String          @id @default(uuid())
  purchaseOrderId  String          @map("purchase_order_id")
  productId        String          @map("product_id")
  orderedQuantity  Int             @map("ordered_quantity")
  receivedQuantity Int             @default(0) @map("received_quantity")
  unitPrice        Decimal         @map("unit_price") @db.Decimal(10, 2)
  status           OrderItemStatus @default(PENDING)
  createdAt        DateTime        @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Stok           @relation("PurchaseOrderItemStok", fields: [productId], references: [id])
  invoiceItems  FaturaKalemi[] @relation("PurchaseOrderItemFaturaKalemi")

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// Order Status Enum
enum OrderStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

// Order Item Status Enum
enum OrderItemStatus {
  PENDING
  PARTIAL
  COMPLETED
}

// ============= BASİT SİPARİŞ YÖNETİMİ =============

// Basit Sipariş Modeli
model BasitSiparis {
  id        String            @id @default(uuid())
  tenantId  String? // Multi-tenant support
  tenant    Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firmaId   String // Cari ID (tedarikçi)
  urunId    String // Stok ID
  miktar    Int
  durum     BasitSiparisDurum @default(ONAY_BEKLIYOR)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // İlişkiler
  firma Cari @relation("BasitSiparisCari", fields: [firmaId], references: [id])
  urun  Stok @relation("BasitSiparisStok", fields: [urunId], references: [id])

  // Tedarik takibi için
  tedarikEdilenMiktar Int @default(0) // Toplam tedarik edilen miktar

  @@index([tenantId])
  @@index([tenantId, firmaId])
  @@index([tenantId, urunId])
  @@index([firmaId])
  @@index([urunId])
  @@index([durum])
  @@index([createdAt])
  @@map("basit_siparisler")
}

// Basit Sipariş Durum Enum
enum BasitSiparisDurum {
  ONAY_BEKLIYOR
  ONAYLANDI
  SIPARIS_VERILDI
  FATURALANDI
  IPTAL_EDILDI
}

// ============= SATIN ALMA SİPARİŞ YÖNETİMİ =============

model SatınAlmaSiparisi {
  id          String                 @id @default(uuid())
  siparisNo   String
  tenantId    String? // Multi-tenant support
  tenant      Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cariId      String // Tedarikçi
  tarih       DateTime               @default(now())
  vade        DateTime?
  iskonto     Decimal                @default(0) @db.Decimal(10, 2)
  toplamTutar Decimal                @db.Decimal(12, 2)
  kdvTutar    Decimal                @db.Decimal(12, 2)
  genelToplam Decimal                @db.Decimal(12, 2)
  aciklama    String?
  durum       SatınAlmaSiparisDurum @default(BEKLEMEDE)
  faturaNo    String? // Sipariş faturalandırıldığında fatura numarası

  // Audit fields
  createdBy String? // User ID
  updatedBy String? // User ID
  deletedAt DateTime? // Soft delete
  deletedBy String? // User ID who deleted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cari                  Cari                         @relation("SatınAlmaSiparisiCari", fields: [cariId], references: [id])
  kalemler              SatınAlmaSiparisKalemi[]
  logs                  SatınAlmaSiparisLog[]
  fatura                Fatura?                      @relation("SatınAlmaSiparisiFatura")
  deliveryNoteId        String?                      // İrsaliye ID (nullable)
  irsaliye              SatınAlmaIrsaliyesi?         @relation("SatınAlmaSiparisIrsaliye", fields: [deliveryNoteId], references: [id])
  kaynakIrsaliyeleri    SatınAlmaIrsaliyesi[]        @relation("IrsaliyeKaynakSatınAlmaSiparis") // Bu siparişten oluşturulan irsaliyeler

  createdByUser User? @relation("SatınAlmaSiparisiCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("SatınAlmaSiparisiUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("SatınAlmaSiparisiDeletedBy", fields: [deletedBy], references: [id])

  @@unique([siparisNo, tenantId])
  @@unique([deliveryNoteId]) // One-to-one relation için unique
  @@index([tenantId])
  @@index([tenantId, siparisNo])
  @@index([cariId])
  @@index([durum])
  @@index([createdAt])
  @@map("satin_alma_siparisleri")
}

model SatınAlmaSiparisKalemi {
  id                  String   @id @default(uuid())
  satınAlmaSiparisId String
  stokId              String
  miktar              Int
  sevkEdilenMiktar    Int      @default(0) // Sevk edilen miktar
  birimFiyat          Decimal  @db.Decimal(10, 2)
  kdvOrani            Int
  kdvTutar            Decimal  @db.Decimal(10, 2)
  tutar               Decimal  @db.Decimal(10, 2)
  createdAt           DateTime @default(now())

  satınAlmaSiparisi SatınAlmaSiparisi @relation(fields: [satınAlmaSiparisId], references: [id], onDelete: Cascade)
  stok               Stok               @relation("SatınAlmaSiparisKalemiStok", fields: [stokId], references: [id])

  @@index([satınAlmaSiparisId])
  @@index([stokId])
  @@map("satin_alma_siparis_kalemleri")
}

model SatınAlmaSiparisLog {
  id                  String    @id @default(uuid())
  satınAlmaSiparisId String
  userId              String?
  actionType          LogAction
  changes             String? // JSON string
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime  @default(now())

  satınAlmaSiparisi SatınAlmaSiparisi @relation(fields: [satınAlmaSiparisId], references: [id], onDelete: Cascade)
  user               User?              @relation("SatınAlmaSiparisLogUser", fields: [userId], references: [id])

  @@index([satınAlmaSiparisId])
  @@index([userId])
  @@map("satin_alma_siparis_logs")
}

enum SatınAlmaSiparisDurum {
  BEKLEMEDE // Beklemede
  HAZIRLANIYOR // Hazırlanıyor
  HAZIRLANDI // Hazırlandı
  SEVK_EDILDI // Sevk Edildi
  KISMI_SEVK // Kısmi Sevk
  SIPARIS_VERILDI // Sipariş Verildi
  FATURALANDI // Faturalandırıldı
  IPTAL // İptal
}

// ============= SATIN ALMA İRSALİYESİ =============

model SatınAlmaIrsaliyesi {
  id             String            @id @default(uuid())
  irsaliyeNo     String
  irsaliyeTarihi DateTime          @default(now())
  tenantId       String? // Multi-tenant support
  tenant         Tenant?           @relation("SatınAlmaIrsaliyesiTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  cariId         String // Tedarikçi
  depoId         String? // Opsiyonel
  kaynakTip      IrsaliyeKaynakTip
  kaynakId       String? // Sipariş ID veya null
  durum          IrsaliyeDurum     @default(FATURALANMADI)
  toplamTutar    Decimal           @db.Decimal(12, 2)
  kdvTutar       Decimal           @db.Decimal(12, 2)
  genelToplam    Decimal           @db.Decimal(12, 2)
  iskonto        Decimal           @default(0) @db.Decimal(10, 2)
  aciklama       String?

  // Audit fields
  createdBy String? // User ID
  updatedBy String? // User ID
  deletedAt DateTime? // Soft delete
  deletedBy String? // User ID who deleted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cari                    Cari                      @relation("SatınAlmaIrsaliyesiCari", fields: [cariId], references: [id])
  depo                    Warehouse?                @relation("SatınAlmaIrsaliyesiDepo", fields: [depoId], references: [id])
  kaynakSiparis           SatınAlmaSiparisi?        @relation("IrsaliyeKaynakSatınAlmaSiparis", fields: [kaynakId], references: [id])
  siparisFromDeliveryNote SatınAlmaSiparisi?        @relation("SatınAlmaSiparisIrsaliye") // SatınAlmaSiparisi.deliveryNoteId back-relation
  kalemler                SatınAlmaIrsaliyesiKalemi[]
  faturalar               Fatura[]                  @relation("SatınAlmaIrsaliyesiFatura")
  logs                    SatınAlmaIrsaliyesiLog[]

  createdByUser User? @relation("SatınAlmaIrsaliyesiCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("SatınAlmaIrsaliyesiUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("SatınAlmaIrsaliyesiDeletedBy", fields: [deletedBy], references: [id])

  @@unique([irsaliyeNo, tenantId])
  @@index([tenantId])
  @@index([tenantId, irsaliyeNo])
  @@index([tenantId, durum])
  @@index([tenantId, irsaliyeTarihi])
  @@index([cariId])
  @@index([durum])
  @@index([kaynakId])
  @@map("satin_alma_irsaliyeleri")
}

model SatınAlmaIrsaliyesiKalemi {
  id         String   @id @default(uuid())
  irsaliyeId String
  stokId     String
  miktar     Int
  birimFiyat Decimal  @db.Decimal(10, 2)
  kdvOrani   Int
  kdvTutar   Decimal  @db.Decimal(10, 2)
  tutar      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  irsaliye SatınAlmaIrsaliyesi @relation(fields: [irsaliyeId], references: [id], onDelete: Cascade)
  stok     Stok                 @relation("SatınAlmaIrsaliyesiKalemiStok", fields: [stokId], references: [id])

  @@index([irsaliyeId])
  @@index([stokId])
  @@map("satin_alma_irsaliyesi_kalemleri")
}

model SatınAlmaIrsaliyesiLog {
  id         String    @id @default(uuid())
  irsaliyeId String
  userId     String?
  actionType LogAction
  changes    String? // JSON string
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  irsaliye SatınAlmaIrsaliyesi @relation(fields: [irsaliyeId], references: [id], onDelete: Cascade)
  user     User?                @relation("SatınAlmaIrsaliyesiLogUser", fields: [userId], references: [id])

  @@index([irsaliyeId])
  @@index([userId])
  @@map("satin_alma_irsaliyesi_logs")
}

// ============= SAAS LİSANSLAMA SİSTEMİ =============

// Modüller (Depo Yönetimi, vb.)
model Module {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  description  String?
  price        Decimal         @db.Decimal(10, 2) // Lisans başına fiyat
  currency     String          @default("TRY")
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  licenses     ModuleLicense[]
  userLicenses UserLicense[]

  @@index([slug])
  @@index([isActive])
  @@map("modules")
}

// Modül lisansları (Subscription'a bağlı)
model ModuleLicense {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id])
  quantity       Int          @default(1) // Satın alınan lisans sayısı
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([subscriptionId])
  @@index([moduleId])
  @@map("module_licenses")
}

// Kullanıcı lisansları (Kullanıcıya atanan lisanslar)
model UserLicense {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseType LicenseType
  moduleId    String? // Modül lisansı ise modül ID
  module      Module?     @relation(fields: [moduleId], references: [id])
  assignedBy  String? // Lisansı atayan kullanıcı ID
  assignedAt  DateTime    @default(now())
  revokedAt   DateTime? // İptal edilme tarihi
  revokedBy   String? // İptal eden kullanıcı ID
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, licenseType, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@index([licenseType])
  @@map("user_licenses")
}

enum LicenseType {
  BASE_PLAN // Ana paket lisansı (giriş izni)
  MODULE // Modül lisansı (ek özellik izni)
}

// Kullanıcı davetleri
model Invitation {
  id         String           @id @default(cuid())
  email      String
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy  String // Davet eden kullanıcı ID
  token      String           @unique // Davet token'ı
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  acceptedBy String? // Daveti kabul eden kullanıcı ID
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([email])
  @@index([tenantId])
  @@index([token])
  @@index([status])
  @@map("invitations")
}

enum InvitationStatus {
  PENDING // Beklemede
  ACCEPTED // Kabul edildi
  EXPIRED // Süresi doldu
  CANCELLED // İptal edildi
}

