// Yedek Parça Otomasyonu - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= SAAS MULTI-TENANT YAPISI =============

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
  DELETED
}

model Tenant {
  id        String       @id @default(cuid())
  uuid      String       @unique @default(uuid())
  name      String
  subdomain String?      @unique
  domain    String?      @unique
  status    TenantStatus @default(TRIAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users                User[]
  subscription         Subscription?
  settings             TenantSettings?
  invoices             Fatura[]
  auditLogs            AuditLog[]
  stoklar              Stok[]
  cariler              Cari[]
  siparisler           Siparis[]
  teklifler            Teklif[]
  tahsilatlar          Tahsilat[]
  kasalar              Kasa[]
  sayimlar             Sayim[]
  masraflar            Masraf[]
  personeller          Personel[]
  purchaseOrders       PurchaseOrder[]
  basitSiparisler      BasitSiparis[]
  satinAlmaSiparisleri SatınAlmaSiparisi[]
  warehouses           Warehouse[]
  bankaHavaleler       BankaHavale[]
  cekSenetler          CekSenet[]
  invitations          Invitation[]
  satisIrsaliyeleri    SatisIrsaliyesi[]    @relation("SatisIrsaliyesiTenant")
  satınAlmaIrsaliyeleri SatınAlmaIrsaliyesi[] @relation("SatınAlmaIrsaliyesiTenant")

  // Servis Modülü
  vehicles             Vehicle[]
  technicians          Technician[]
  workOrders           WorkOrder[]
  maintenanceReminders VehicleMaintenanceReminder[]

  @@index([subdomain])
  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("tenants")
}

model TenantSettings {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName String?
  taxNumber   String?
  address     String?
  logoUrl     String?
  features    Json? // JSON: { "feature1": true, "feature2": false }
  limits      Json? // JSON: { "maxUsers": 10, "maxInvoices": 1000 }
  timezone    String   @default("Europe/Istanbul")
  locale      String   @default("tr-TR")
  currency    String   @default("TRY")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tenant_settings")
}

enum SubscriptionStatus {
  PENDING
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("TRY")
  billingPeriod BillingPeriod  @default(MONTHLY)
  trialDays     Int            @default(0)
  baseUserLimit Int            @default(1) // Ana paket kullanıcı limiti
  features      Json? // JSON: { "feature1": true, "feature2": false }
  limits        Json? // JSON: { "maxUsers": 10, "maxInvoices": 1000 }
  isActive      Boolean        @default(true)
  isPopular     Boolean        @default(false)
  isBasePlan    Boolean        @default(true) // Ana paket mi, eklenti mi
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive])
  @@index([isBasePlan])
  @@map("plans")
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan               @relation(fields: [planId], references: [id])
  status                SubscriptionStatus @default(TRIAL)
  startDate             DateTime           @default(now())
  endDate               DateTime
  trialEndsAt           DateTime?
  canceledAt            DateTime?
  nextBillingDate       DateTime?
  lastBillingDate       DateTime?
  autoRenew             Boolean            @default(true)
  iyzicoSubscriptionRef String?            @unique
  additionalUsers       Int                @default(0) // Ek satın alınan kullanıcı sayısı
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  payments              Payment[]
  moduleLicenses        ModuleLicense[] // Satın alınan modül lisansları

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  CANCELED
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("TRY")
  status          PaymentStatus @default(PENDING)
  iyzicoPaymentId String?       @unique
  iyzicoToken     String?       @unique
  conversationId  String?       @unique
  invoiceNumber   String?
  invoiceUrl      String?
  paidAt          DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  paymentMethod   String? // credit_card, debit_card
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([subscriptionId])
  @@index([status])
  @@index([iyzicoPaymentId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("payments")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tenantId   String?
  action     String // USER_LOGIN, SUBSCRIPTION_CREATED, PAYMENT_FAILED, etc.
  resource   String? // users, subscriptions, payments
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============= KULLANICI VE YETKİLENDİRME =============

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id            String        @id @default(uuid())
  uuid          String        @unique @default(uuid())
  email         String
  username      String
  password      String
  firstName     String?
  lastName      String?
  fullName      String
  phone         String?
  avatarUrl     String?
  role          UserRole      @default(USER)
  status        UserStatus    @default(ACTIVE)
  isActive      Boolean       @default(true)
  refreshToken  String?
  tokenVersion  Int           @default(0) // Token versioning for single session control
  tenantId      String?
  tenant        Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  emailVerified Boolean       @default(false)
  lastLoginAt   DateTime?
  sessions      Session[]
  licenses      UserLicense[] // Kullanıcı lisansları
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations for audit trail
  createdFaturalar           Fatura[]               @relation("FaturaCreatedBy")
  updatedFaturalar           Fatura[]               @relation("FaturaUpdatedBy")
  deletedFaturalar           Fatura[]               @relation("FaturaDeletedBy")
  faturaLogs                 FaturaLog[]
  createdKasalar             Kasa[]                 @relation("KasaCreatedBy")
  updatedKasalar             Kasa[]                 @relation("KasaUpdatedBy")
  createdKasaHareketler      KasaHareket[]          @relation("KasaHareketCreatedBy")
  createdTahsilatlar         Tahsilat[]             @relation("TahsilatCreatedBy")
  createdBankaHavaleler      BankaHavale[]          @relation("BankaHavaleCreatedBy")
  updatedBankaHavaleler      BankaHavale[]          @relation("BankaHavaleUpdatedBy")
  deletedBankaHavaleler      BankaHavale[]          @relation("BankaHavaleDeletedBy")
  deletedBankaHavaleRecords  DeletedBankaHavale[]   @relation("DeletedBankaHavaleDeletedBy")
  bankaHavaleLogs            BankaHavaleLog[]
  createdCekSenetler         CekSenet[]             @relation("CekSenetCreatedBy")
  updatedCekSenetler         CekSenet[]             @relation("CekSenetUpdatedBy")
  deletedCekSenetler         CekSenet[]             @relation("CekSenetDeletedBy")
  deletedCekSenetRecords     DeletedCekSenet[]      @relation("DeletedCekSenetDeletedBy")
  cekSenetLogs               CekSenetLog[]
  createdPersoneller         Personel[]             @relation("PersonelCreatedBy")
  updatedPersoneller         Personel[]             @relation("PersonelUpdatedBy")
  createdPersonelOdemeler    PersonelOdeme[]        @relation("PersonelOdemeCreatedBy")
  stockMoves                 StockMove[]            @relation("StockMoveCreatedBy")
  createdSiparisler          Siparis[]              @relation("SiparisCreatedBy")
  updatedSiparisler          Siparis[]              @relation("SiparisUpdatedBy")
  deletedSiparisler          Siparis[]              @relation("SiparisDeletedBy")
  siparisLogs                SiparisLog[]
  siparisHazirliklar         SiparisHazirlik[]      @relation("SiparisHazirlikCreatedBy")
  createdSatisIrsaliyeleri   SatisIrsaliyesi[]      @relation("SatisIrsaliyesiCreatedBy")
  updatedSatisIrsaliyeleri   SatisIrsaliyesi[]      @relation("SatisIrsaliyesiUpdatedBy")
  deletedSatisIrsaliyeleri   SatisIrsaliyesi[]      @relation("SatisIrsaliyesiDeletedBy")
  satisIrsaliyesiLogs        SatisIrsaliyesiLog[]   @relation("SatisIrsaliyesiLogUser")
  createdTeklifler           Teklif[]               @relation("TeklifCreatedBy")
  updatedTeklifler           Teklif[]               @relation("TeklifUpdatedBy")
  deletedTeklifler           Teklif[]               @relation("TeklifDeletedBy")
  teklifLogs                 TeklifLog[]            @relation("TeklifLogUser")
  createdSayimlar            Sayim[]                @relation("SayimCreatedBy")
  updatedSayimlar            Sayim[]                @relation("SayimUpdatedBy")
  createdSatinAlmaSiparisler SatınAlmaSiparisi[]   @relation("SatınAlmaSiparisiCreatedBy")
  updatedSatinAlmaSiparisler SatınAlmaSiparisi[]   @relation("SatınAlmaSiparisiUpdatedBy")
  deletedSatinAlmaSiparisler SatınAlmaSiparisi[]   @relation("SatınAlmaSiparisiDeletedBy")
  satinAlmaSiparisLogs       SatınAlmaSiparisLog[] @relation("SatınAlmaSiparisLogUser")
  createdSatınAlmaIrsaliyeleri   SatınAlmaIrsaliyesi[]      @relation("SatınAlmaIrsaliyesiCreatedBy")
  updatedSatınAlmaIrsaliyeleri   SatınAlmaIrsaliyesi[]      @relation("SatınAlmaIrsaliyesiUpdatedBy")
  deletedSatınAlmaIrsaliyeleri   SatınAlmaIrsaliyesi[]      @relation("SatınAlmaIrsaliyesiDeletedBy")
  satınAlmaIrsaliyesiLogs        SatınAlmaIrsaliyesiLog[]   @relation("SatınAlmaIrsaliyesiLogUser")
  onayladigiSayimlar         Sayim[]                @relation("SayimOnaylayan")
  createdPriceCards          PriceCard[]            @relation("PriceCardCreatedBy")
  updatedPriceCards          PriceCard[]            @relation("PriceCardUpdatedBy")
  approvedWorkOrderLines     WorkOrderLine[]        @relation("ApprovedByUser")
  createdMaasOdemeler        MaasOdeme[]            @relation("MaasOdemeCreatedBy")
  createdAvanslar            Avans[]                @relation("AvansCreatedBy")


  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  ADMIN
  USER
  VIEWER
  SUPPORT
  MANAGER
}

// ============= STOK YÖNETİMİ =============

model Stok {
  id                String   @id @default(uuid())
  stokKodu          String
  tenantId          String? // Multi-tenant support
  tenant            Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stokAdi           String
  aciklama          String?
  birim             String
  alisFiyati        Decimal  @db.Decimal(10, 2)
  satisFiyati       Decimal  @db.Decimal(10, 2)
  kdvOrani          Int      @default(20)
  kritikStokMiktari Int      @default(0)
  kategori          String?
  anaKategori       String?
  altKategori       String?
  marka             String?
  model             String?
  oem               String?
  olcu              String?
  raf               String?
  barkod            String?
  tedarikciKodu     String? // Tedarikçi kodu
  esdegerGrupId     String?
  // Araç bilgileri
  aracMarka         String? // Araç markası (Toyota, Honda, BMW, vb.)
  aracModel         String? // Araç modeli (Corolla, Civic, 320i, vb.)
  aracMotorHacmi    String? // Araç motor hacmi (1.4L, 1.6L, 2.0L, vb.)
  aracYakitTipi     String? // Araç yakıt tipi (Benzin, Dizel, Hibrit, vb.)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  esdegerGrup               EsdegerGrup?              @relation(fields: [esdegerGrupId], references: [id])
  esdegers                  StokEsdeger[]             @relation("Stok1")
  esdegers2                 StokEsdeger[]             @relation("Stok2")
  faturaKalemleri           FaturaKalemi[]
  siparisKalemleri          SiparisKalemi[]
  teklifKalemleri           TeklifKalemi[]
  satisIrsaliyesiKalemleri  SatisIrsaliyesiKalemi[]   @relation("SatisIrsaliyesiKalemiStok")
  stokHareketleri           StokHareket[]
  urunRaflar                UrunRaf[]
  productBarcodes           ProductBarcode[]
  productLocationStocks     ProductLocationStock[]
  stockMoves                StockMove[]
  sayimKalemleri            SayimKalemi[]
  priceCards                PriceCard[]
  costHistory               StockCostHistory[]
  purchaseOrderItems        PurchaseOrderItem[]       @relation("PurchaseOrderItemStok")
  basitSiparisler           BasitSiparis[]            @relation("BasitSiparisStok")
  satinAlmaSiparisKalemleri SatınAlmaSiparisKalemi[] @relation("SatınAlmaSiparisKalemiStok")
  satinAlmaIrsaliyesiKalemleri SatınAlmaIrsaliyesiKalemi[] @relation("SatınAlmaIrsaliyesiKalemiStok")

  // Servis Modülü
  workOrderLines       WorkOrderLine[] // İş emri kalemlerinde kullanılan parçalar
  solutionPackageParts SolutionPackagePart[] // Çözüm paketi parçaları

  @@unique([stokKodu, tenantId])
  @@unique([barkod, tenantId])
  @@index([tenantId])
  @@index([tenantId, stokKodu])
  @@index([tenantId, barkod])
  @@map("stoklar")
}

model PriceCard {
  id            String        @id @default(uuid())
  stokId        String        @map("stok_id")
  type          PriceCardType
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("TRY")
  effectiveFrom DateTime?     @map("effective_from")
  effectiveTo   DateTime?     @map("effective_to")
  note          String?
  createdBy     String?       @map("created_by")
  updatedBy     String?       @map("updated_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  stok          Stok  @relation(fields: [stokId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("PriceCardCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("PriceCardUpdatedBy", fields: [updatedBy], references: [id])

  @@index([stokId, type, createdAt])
  @@map("price_cards")
}

enum PriceCardType {
  SALE
  PURCHASE
}

model StockCostHistory {
  id          String   @id @default(uuid())
  stokId      String   @map("stok_id")
  cost        Decimal  @db.Decimal(12, 4)
  method      String   @default("WEIGHTED_AVERAGE")
  computedAt  DateTime @default(now()) @map("computed_at")
  marka       String?
  anaKategori String?
  altKategori String?
  note        String?

  stok Stok @relation(fields: [stokId], references: [id], onDelete: Cascade)

  @@index([stokId, computedAt])
  @@map("stock_cost_history")
}

model EsdegerGrup {
  id        String   @id @default(uuid())
  grupAdi   String?
  aciklama  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  urunler Stok[]

  @@map("esdeger_gruplar")
}

model StokEsdeger {
  id        String   @id @default(uuid())
  stok1Id   String
  stok2Id   String
  createdAt DateTime @default(now())

  stok1 Stok @relation("Stok1", fields: [stok1Id], references: [id], onDelete: Cascade)
  stok2 Stok @relation("Stok2", fields: [stok2Id], references: [id], onDelete: Cascade)

  @@unique([stok1Id, stok2Id])
  @@map("stok_esdegers")
}

model StokHareket {
  id          String      @id @default(uuid())
  stokId      String
  hareketTipi HareketTipi
  miktar      Int
  birimFiyat  Decimal     @db.Decimal(10, 2)
  aciklama    String?
  createdAt   DateTime    @default(now())

  stok Stok @relation(fields: [stokId], references: [id], onDelete: Cascade)

  @@map("stok_hareketleri")
}

enum HareketTipi {
  GIRIS
  CIKIS
  SATIS
  IADE
  SAYIM
  SAYIM_FAZLA // Sayım fazlası (artış)
  SAYIM_EKSIK // Sayım eksiği (azalış)
}

// ============= CARİ YÖNETİMİ =============

model Cari {
  id           String      @id @default(uuid())
  cariKodu     String
  tenantId     String? // Multi-tenant support
  tenant       Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unvan        String
  tip          CariTip
  sirketTipi   SirketTipi? @default(KURUMSAL) // Kurumsal veya Şahıs
  vergiNo      String?
  vergiDairesi String?
  tcKimlikNo   String? // Şahıs şirketi için TC Kimlik No (11 karakter)
  isimSoyisim  String? // Şahıs şirketi sahibi adı soyadı
  telefon      String?
  email        String?
  ulke         String?     @default("Türkiye")
  il           String?
  ilce         String?
  adres        String?
  yetkili      String?
  bakiye       Decimal     @default(0) @db.Decimal(12, 2)
  vadeSuresi   Int? // Varsayılan vade süresi (gün cinsinden)
  aktif        Boolean     @default(true) // Kullanım içi/dışı
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  faturalar                 Fatura[]
  tahsilatlar               Tahsilat[]
  cariHareketler            CariHareket[]
  kasaHareketler            KasaHareket[]
  bankaHavaleler            BankaHavale[]
  cekSenetler               CekSenet[]
  bankaHesapHareketler      BankaHesapHareket[]
  firmaKrediKartiHareketler FirmaKrediKartiHareket[]
  siparisler                Siparis[]
  teklifler                 Teklif[]
  purchaseOrders            PurchaseOrder[]          @relation("PurchaseOrderSupplier")
  basitSiparisler           BasitSiparis[]           @relation("BasitSiparisCari")
  satinAlmaSiparisleri      SatınAlmaSiparisi[]     @relation("SatınAlmaSiparisiCari")
  satisIrsaliyeleri         SatisIrsaliyesi[]        @relation("SatisIrsaliyesiCari")
  satınAlmaIrsaliyeleri     SatınAlmaIrsaliyesi[]    @relation("SatınAlmaIrsaliyesiCari")

  // Servis Modülü
  vehicles   Vehicle[] // Müşterinin araçları
  workOrders WorkOrder[] @relation("WorkOrderCustomer")

  @@unique([cariKodu, tenantId])
  @@index([tenantId])
  @@index([tenantId, cariKodu])
  @@map("cariler")
}

enum CariTip {
  MUSTERI
  TEDARIKCI
  HER_IKISI
}

enum SirketTipi {
  KURUMSAL // Ltd, A.Ş vb.
  SAHIS // Şahıs işletmesi
}

model CariHareket {
  id        String     @id @default(uuid())
  cariId    String
  tip       BorcAlacak
  tutar     Decimal    @db.Decimal(12, 2)
  bakiye    Decimal    @db.Decimal(12, 2) // Yürüyen bakiye
  belgeTipi BelgeTipi?
  belgeNo   String?
  tarih     DateTime   @default(now())
  aciklama  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  cari Cari @relation(fields: [cariId], references: [id], onDelete: Cascade)

  @@index([cariId, tarih])
  @@map("cari_hareketler")
}

enum BorcAlacak {
  BORC
  ALACAK
  DEVIR // Açılış devir kaydı
}

enum BelgeTipi {
  FATURA
  TAHSILAT
  ODEME
  CEK_SENET
  DEVIR
  DUZELTME
}

// ============= KASA YÖNETİMİ =============

model Kasa {
  id        String   @id @default(uuid())
  kasaKodu  String
  tenantId  String? // Multi-tenant support
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kasaAdi   String
  kasaTipi  KasaTipi
  bakiye    Decimal  @default(0) @db.Decimal(15, 2) // Toplam bakiye
  aktif     Boolean  @default(true)
  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankaHesaplari     BankaHesabi[] // Banka kasasına bağlı hesaplar
  firmaKrediKartlari FirmaKrediKarti[] // Firma KK kasasına bağlı kartlar
  hareketler         KasaHareket[]
  tahsilatlar        Tahsilat[]
  bankaHavaleler     BankaHavale[]
  cekSenetTahsilat   CekSenet[]
  personelOdemeler   PersonelOdeme[]
  maasOdemeDetaylari MaasOdemeDetay[]
  avanslar           Avans[]
  createdByUser      User?             @relation("KasaCreatedBy", fields: [createdBy], references: [id])
  updatedByUser      User?             @relation("KasaUpdatedBy", fields: [updatedBy], references: [id])


  @@unique([kasaKodu, tenantId])
  @@index([tenantId])
  @@index([tenantId, kasaKodu])
  @@index([kasaTipi])
  @@index([aktif])
  @@map("kasalar")
}

// Banka Kasasına bağlı hesaplar (Vadesiz ve POS)
model BankaHesabi {
  id        String         @id @default(uuid())
  kasaId    String // Hangi Banka kasasına bağlı
  hesapKodu String         @unique
  hesapAdi  String?
  bankaAdi  String // Ziraat, Garanti, İş Bankası vb.
  subeKodu  String?
  subeAdi   String?
  hesapNo   String?
  iban      String?
  hesapTipi BankaHesapTipi // VADESIZ, POS
  bakiye    Decimal        @default(0) @db.Decimal(15, 2)
  aktif     Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  kasa        Kasa                @relation(fields: [kasaId], references: [id], onDelete: Cascade)
  hareketler  BankaHesapHareket[]
  tahsilatlar Tahsilat[] // POS tahsilatları
  maasOdemeDetaylari MaasOdemeDetay[]


  @@index([kasaId])
  @@index([hesapTipi])
  @@map("banka_hesaplari")
}

model BankaHesapHareket {
  id          String   @id @default(uuid())
  hesapId     String
