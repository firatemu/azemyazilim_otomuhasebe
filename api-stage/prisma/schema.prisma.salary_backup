// ============= SERVİS YÖNETİMİ (OTOMOTİV) =============

// İş Emri Durumları
enum WorkOrderStatus {
  ACCEPTED // Kabul edildi
  DIAGNOSIS // Teşhis aşamasında
  WAITING_FOR_APPROVAL // Onay bekliyor
  APPROVED // Onaylandı
  PART_WAITING // Parça bekleniyor
  IN_PROGRESS // İşlemde
  QUALITY_CONTROL // Kalite kontrol
  READY_FOR_DELIVERY // Teslime hazır
  INVOICED // Faturalandırıldı
  CLOSED // Kapatıldı
  CANCELLED // İptal edildi
}

// Servis İş Akışı Durumları (Extended Workflow)
enum ServiceWorkStatus {
  SERVICE_ACCEPTED // Initial state from existing module
  PRE_DIAGNOSIS // Quick assessment
  TECHNICAL_DIAGNOSIS // Detailed technical analysis
  SOLUTION_PROPOSED // Solution package created
  WAITING_MANAGER_APPROVAL // Pending managerial decision
  APPROVED // Manager approved
  PART_SUPPLY // Parts being sourced
  IN_PROGRESS // Active work
  QUALITY_CONTROL // QC inspection
  READY_FOR_BILLING // Handoff to billing
  INVOICED // Invoice created (external)
  CLOSED // Completed and archived
  CANCELLED // Terminated workflow
}

// İş Emri Kalemi Tipi
enum WorkOrderLineType {
  LABOR // İşçilik
  PART // Parça
}

enum PartSource {
  STOCK_DIRECT // Stoktan direkt karşılama
  SUPPLY_REQUEST // Tedarik isteği
}

enum SupplyRequestStatus {
  PENDING // Beklemede
  APPROVED // Onaylandı (eşleştirme yapıldı)
  REJECTED // Reddedildi
}

// Araç Modeli
model Vehicle {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Araç Bilgileri
  plateNumber           String // Plaka
  vin                   String? // Şasi numarası (VIN)
  brand                 String // Marka (Toyota, Honda, BMW, vb.)
  model                 String // Model (Corolla, Civic, 320i, vb.)
  year                  Int? // Model yılı
  firstRegistrationDate DateTime? // İlk tescil tarihi
  engineSize            String? // Motor hacmi (1.4L, 1.6L, 2.0L, vb.)
  fuelType              String? // Yakıt tipi (Benzin, Dizel, Hibrit, vb.)
  color                 String? // Renk
  mileage               Int? // Kilometre

  // Müşteri İlişkisi
  customerId String // Cari ID (araç sahibi)
  customer   Cari   @relation(fields: [customerId], references: [id])

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  workOrders          WorkOrder[]
  maintenanceReminder VehicleMaintenanceReminder?

  @@unique([tenantId, plateNumber])
  @@index([tenantId])
  @@index([tenantId, plateNumber])
  @@index([customerId])
  @@index([vin])
  @@map("vehicles")
}

// Teknisyen Modeli
model Technician {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Kişisel Bilgiler
  code      String // Teknisyen kodu
  firstName String // Ad
  lastName  String // Soyad
  phone     String? // Telefon
  email     String? // E-posta

  // İş Bilgileri
  specialization String? // Uzmanlık alanı
  isActive       Boolean @default(true)

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  workOrders WorkOrder[]
  auditLogs  WorkOrderAuditLog[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, code])
  @@index([isActive])
  @@map("technicians")
}

// İş Emri Modeli
model WorkOrder {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // İş Emri Bilgileri
  workOrderNo String // İş emri numarası
  vehicleId   String // Araç ID
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  customerId  String // Müşteri ID (araç sahibi)
  customer    Cari    @relation("WorkOrderCustomer", fields: [customerId], references: [id])

  // Teknisyen Ataması
  technicianId String? // Atanan teknisyen
  technician   Technician? @relation(fields: [technicianId], references: [id])

  // Durum ve Tarihler
  status            WorkOrderStatus @default(ACCEPTED)
  acceptedAt        DateTime        @default(now()) // Kabul tarihi
  diagnosisAt       DateTime? // Teşhis tarihi
  approvedAt        DateTime? // Onay tarihi
  startedAt         DateTime? // Başlangıç tarihi
  completedAt       DateTime? // Tamamlanma tarihi
  closedAt          DateTime? // Kapatılma tarihi
  estimatedDelivery DateTime? // Tahmini teslim tarihi

  // Şikayet ve Bulgular
  complaint String? @db.Text // Müşteri şikayeti
  findings  String? @db.Text // Teknisyen bulguları

  // Notlar
  internalNotes String? @db.Text // Dahili notlar (müşteriye gösterilmez)

  // Fatura İlişkisi
  invoiceId String? @unique // Fatura ID
  invoice   Fatura? @relation("WorkOrderInvoice", fields: [invoiceId], references: [id])

  // Toplam Tutarlar
  laborTotal     Decimal @default(0) @db.Decimal(12, 2) // İşçilik toplamı
  partsTotal     Decimal @default(0) @db.Decimal(12, 2) // Parça toplamı
  discountAmount Decimal @default(0) @db.Decimal(12, 2) // İskonto
  taxAmount      Decimal @default(0) @db.Decimal(12, 2) // KDV toplamı
  grandTotal     Decimal @default(0) @db.Decimal(12, 2) // Genel toplam

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  lines             WorkOrderLine[]
  auditLogs         WorkOrderAuditLog[]
  statusHistory     WorkOrderStatusHistory[]
  technicalFindings TechnicalFinding[]
  diagnosticNotes   DiagnosticNote[]
  solutionPackages  SolutionPackage[]
  managerApproval   ManagerApproval?
  managerRejections ManagerRejection[]

  @@unique([tenantId, workOrderNo])
  @@index([tenantId])
  @@index([tenantId, workOrderNo])
  @@index([vehicleId])
  @@index([customerId])
  @@index([technicianId])
  @@index([status])
  @@index([acceptedAt])
  @@index([closedAt])
  @@map("work_orders")
}

// İş Emri Kalemi (İşçilik ve Parça)
model WorkOrderLine {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  // Kalem Tipi
  lineType WorkOrderLineType // LABOR veya PART

  // İşçilik için
  description String? // İşçilik açıklaması
  laborHours  Decimal? @db.Decimal(5, 2) // İşçilik saati
  hourlyRate  Decimal? @db.Decimal(10, 2) // Saat ücreti

  // Parça için
  productId String? // Stok ID (parça)
  product   Stok?    @relation(fields: [productId], references: [id])
  quantity  Int      @default(1) // Miktar
  unitPrice Decimal? @db.Decimal(10, 2) // Birim fiyat (nullable - stoktan karşılama için yok)

  // Ortak Alanlar
  discountRate   Decimal @default(0) @db.Decimal(5, 2) // İskonto oranı (%)
  discountAmount Decimal @default(0) @db.Decimal(10, 2) // İskonto tutarı
  taxRate        Int     @default(20) // KDV oranı (%)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2) // KDV tutarı
  lineTotal      Decimal @default(0) @db.Decimal(12, 2) // Satır toplamı (KDV dahil)

  // Parça Durumu (sadece PART için)
  isUsed Boolean   @default(false) // Parça kullanıldı mı?
  usedAt DateTime? // Kullanım tarihi

  // Parça Kaynağı ve Tedarik İsteği Durumu
  partSource          PartSource?          @default(STOCK_DIRECT) // Parça kaynağı
  supplyRequestStatus SupplyRequestStatus? // Tedarik isteği durumu (sadece SUPPLY_REQUEST için)
  requestedAt         DateTime? // Tedarik isteği oluşturulma tarihi
  approvedAt          DateTime? // Onay tarihi
  approvedBy          String? // Onaylayan kullanıcı ID
  approver            User?                @relation("ApprovedByUser", fields: [approvedBy], references: [id])

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workOrderId])
  @@index([lineType])
  @@index([productId])
  @@index([isUsed])
  @@map("work_order_lines")
}

// İş Emri Denetim Logu
model WorkOrderAuditLog {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  // İşlem Bilgileri
  action         String // STATUS_CHANGE, TECHNICIAN_ASSIGNED, APPROVAL, vb.
  previousStatus WorkOrderStatus? // Önceki durum
  newStatus      WorkOrderStatus? // Yeni durum

  // Teknisyen Ataması için
  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id])

  // Ek Bilgiler
  details   String? @db.Text // JSON formatında ek detaylar
  userId    String? // İşlemi yapan kullanıcı ID
  ipAddress String? // IP adresi
  userAgent String? // User agent

  // Zaman
  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([action])
  @@index([createdAt])
  @@map("work_order_audit_logs")
}

// İş Emri Durum Geçmişi (Service Workflow Extension)
model WorkOrderStatusHistory {
  id          String             @id @default(cuid())
  tenantId    String
  workOrderId String
  fromStatus  ServiceWorkStatus?
  toStatus    ServiceWorkStatus
  changedBy   String
  changedAt   DateTime           @default(now())
  reason      String?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, workOrderId])
  @@index([tenantId, changedAt])
  @@map("work_order_status_history")
}

// Teknik Bulgu (Technical Finding)
model TechnicalFinding {
  id          String   @id @default(cuid())
  tenantId    String
  workOrderId String
  title       String   @db.VarChar(200)
  description String   @db.Text
  createdBy   String
  createdAt   DateTime @default(now())
  version     Int      @default(1)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, workOrderId])
  @@index([tenantId, createdAt])
  @@map("technical_findings")
}

// Teşhis Notu (Diagnostic Note)
model DiagnosticNote {
  id          String   @id @default(cuid())
  tenantId    String
  workOrderId String
  note        String   @db.Text
  createdBy   String
  createdAt   DateTime @default(now())
  version     Int      @default(1)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, workOrderId])
  @@index([tenantId, createdAt])
  @@map("diagnostic_notes")
}

// Çözüm Paketi (Solution Package)
model SolutionPackage {
  id                       String   @id @default(cuid())
  tenantId                 String
  workOrderId              String
  name                     String   @db.VarChar(200)
  description              String   @db.Text
  estimatedDurationMinutes Int
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  version                  Int      @default(1)

  workOrder         WorkOrder             @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  parts             SolutionPackagePart[]
  managerApprovals  ManagerApproval[]
  managerRejections ManagerRejection[]

  @@index([tenantId, workOrderId])
  @@index([tenantId, createdAt])
  @@map("solution_packages")
}

// Çözüm Paketi Parçası (Solution Package Part)
model SolutionPackagePart {
  id                String  @id @default(cuid())
  solutionPackageId String
  productId         String
  quantity          Decimal @db.Decimal(10, 3)

  solutionPackage SolutionPackage @relation(fields: [solutionPackageId], references: [id], onDelete: Cascade)
  product         Stok            @relation(fields: [productId], references: [id])

  @@unique([solutionPackageId, productId])
  @@index([solutionPackageId])
  @@map("solution_package_parts")
}

// Yönetici Onayı (Manager Approval)
model ManagerApproval {
  id                String    @id @default(cuid())
  tenantId          String
  workOrderId       String    @unique
  solutionPackageId String
  approvedBy        String
  approvedAt        DateTime  @default(now())
  approvalNote      String?   @db.Text
  deletedAt         DateTime? // Soft delete for invalidation

  workOrder       WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  solutionPackage SolutionPackage @relation(fields: [solutionPackageId], references: [id], onDelete: Cascade)

  @@index([tenantId, workOrderId])
  @@index([tenantId, approvedAt])
  @@index([deletedAt])
  @@map("manager_approvals")
}

// Yönetici Reddi (Manager Rejection)
model ManagerRejection {
  id                String   @id @default(cuid())
  tenantId          String
  workOrderId       String
  solutionPackageId String
  rejectedBy        String
  rejectedAt        DateTime @default(now())
  rejectionReason   String   @db.Text

  workOrder       WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  solutionPackage SolutionPackage @relation(fields: [solutionPackageId], references: [id], onDelete: Cascade)

  @@index([tenantId, workOrderId])
  @@index([tenantId, rejectedAt])
  @@map("manager_rejections")
}

// Araç Bakım Hatırlatması
model VehicleMaintenanceReminder {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Araç İlişkisi (her araç için tek hatırlatma)
  vehicleId String  @unique
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Son Servis Bilgileri
  lastServiceDate DateTime // Son servis tarihi
  lastWorkOrderId String? // Son iş emri ID (referans)
  lastMileage     Int? // Son servis kilometresi

  // Hatırlatma Bilgileri
  nextReminderDate DateTime // Sonraki hatırlatma tarihi
  reminderSent     Boolean   @default(false) // Hatırlatma gönderildi mi?
  reminderSentAt   DateTime? // Hatırlatma gönderim tarihi

  // Notlar
  notes String? @db.Text

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, vehicleId])
  @@index([tenantId])
  @@index([vehicleId])
  @@index([nextReminderDate])
  @@index([reminderSent])
  @@map("vehicle_maintenance_reminders")
}

// ============= MAAŞ TAKİP VE ÖDEME SİSTEMİ =============

// Maaş Planı - Her personel için 12 aylık plan
model MaasPlani {
  id         String    @id @default(uuid())
  personelId String
  yil        Int       // 2026
  ay         Int       // 1-12
  maas       Decimal   @db.Decimal(10, 2) // Planlanan maaş
  prim       Decimal   @default(0) @db.Decimal(10, 2) // Planlanan prim
  toplam     Decimal   @db.Decimal(10, 2) // maas + prim
  durum      MaasDurum @default(ODENMEDI)
  odenenTutar Decimal  @default(0) @db.Decimal(10, 2)
  kalanTutar Decimal   @db.Decimal(10, 2) // toplam - odenenTutar
  aktif      Boolean   @default(true) // Personel çıkış yaptıysa false
  aciklama   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  personel       Personel             @relation(fields: [personelId], references: [id], onDelete: Cascade)
  odemeler       MaasOdeme[]
  mahsuplasmalar AvansMahsuplasma[]

  @@unique([personelId, yil, ay])
  @@index([personelId, yil])
  @@index([durum])
  @@index([yil, ay])
  @@map("maas_planlari")
}

enum MaasDurum {
  ODENMEDI
  KISMI_ODENDI
  TAMAMEN_ODENDI
}

// Maaş Ödeme - Bir plana ait ödemeler (parçalı ödeme desteği)
model MaasOdeme {
  id         String   @id @default(uuid())
  planId     String   // Hangi aya ait
  personelId String
  tutar      Decimal  @db.Decimal(10, 2)
  tarih      DateTime @default(now())
  aciklama   String?
  createdBy  String?
  createdAt  DateTime @default(now())

  plan           MaasPlani        @relation(fields: [planId], references: [id], onDelete: Cascade)
  personel       Personel         @relation(fields: [personelId], references: [id], onDelete: Cascade)
  odemeDetaylari MaasOdemeDetay[]
  createdByUser  User?            @relation("MaasOdemeCreatedBy", fields: [createdBy], references: [id])

  @@index([planId])
  @@index([personelId])
  @@index([tarih])
  @@map("maas_odemeler")
}

// Maaş Ödeme Detay - Çoklu ödeme yöntemi desteği
model MaasOdemeDetay {
  id           String    @id @default(uuid())
  odemeId      String
  odemeTipi    OdemeTipi
  tutar        Decimal   @db.Decimal(10, 2)
  kasaId       String?   // Nakit ödeme için
  bankaHesapId String?   // Banka havalesi için
  referansNo   String?   // Dekont/havale no
  aciklama     String?
  createdAt    DateTime  @default(now())

  odeme      MaasOdeme    @relation(fields: [odemeId], references: [id], onDelete: Cascade)
  kasa       Kasa?        @relation(fields: [kasaId], references: [id])
  bankaHesap BankaHesabi? @relation(fields: [bankaHesapId], references: [id])

  @@index([odemeId])
  @@index([kasaId])
  @@index([bankaHesapId])
  @@map("maas_odeme_detaylari")
}



// Avans Sistemi
model Avans {
  id         String     @id @default(uuid())
  personelId String
  tutar      Decimal    @db.Decimal(10, 2)
  tarih      DateTime   @default(now())
  aciklama   String?
  kasaId     String?    // Hangi kasadan verildi

  // Mahsuplaştırma
  mahsupEdilen Decimal    @default(0) @db.Decimal(10, 2)
  kalan        Decimal    @db.Decimal(10, 2) // tutar - mahsupEdilen
  durum        AvansDurum @default(ACIK)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personel       Personel             @relation(fields: [personelId], references: [id], onDelete: Cascade)
  kasa           Kasa?                @relation(fields: [kasaId], references: [id])
  mahsuplasmalar AvansMahsuplasma[]
  createdByUser  User?                @relation("AvansCreatedBy", fields: [createdBy], references: [id])

  @@index([personelId])
  @@index([durum])
  @@index([tarih])
  @@index([kasaId])
  @@map("avanslar")
}

enum AvansDurum {
  ACIK   // Henüz mahsup edilmedi
  KISMI  // Kısmen mahsup edildi
  KAPALI // Tamamen mahsup edildi
}

// Avans Mahsuplaştırma - Hangi aydan ne kadar düşüldü
model AvansMahsuplasma {
  id       String   @id @default(uuid())
  avansId  String
  planId   String   // Hangi aydan düşüldü
  tutar    Decimal  @db.Decimal(10, 2)
  tarih    DateTime @default(now())
  aciklama String?

  avans Avans     @relation(fields: [avansId], references: [id], onDelete: Cascade)
  plan  MaasPlani @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([avansId])
  @@index([planId])
  @@map("avans_mahsuplasmalar")
}
