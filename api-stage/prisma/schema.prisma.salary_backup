// ============= FATURA YÖNETİMİ =============

model Fatura {
  id                  String      @id @default(uuid())
  faturaNo            String
  faturaTipi          FaturaTipi
  tenantId            String? // Multi-tenant support
  tenant              Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cariId              String
  tarih               DateTime    @default(now())
  vade                DateTime?
  iskonto             Decimal     @default(0) @db.Decimal(10, 2)
  toplamTutar         Decimal     @db.Decimal(12, 2)
  kdvTutar            Decimal     @db.Decimal(12, 2)
  genelToplam         Decimal     @db.Decimal(12, 2)
  aciklama            String?
  durum               FaturaDurum @default(ACIK)
  odenecekTutar       Decimal?    @db.Decimal(12, 2) // FIFO: Kalan ödenmemiş tutar
  odenenTutar         Decimal     @default(0) @db.Decimal(12, 2) // FIFO: Toplam ödenen tutar
  siparisNo           String? // Sipariş numarası (sipariş faturalandırıldığında doldurulur)
  purchaseOrderId     String?     @unique // Yeni: PurchaseOrder ilişkisi
  satinAlmaSiparisiId String?     @unique
  deliveryNoteId      String? // İrsaliye ID (SATIS faturaları için zorunlu, ALIS için null olabilir)
  satinAlmaIrsaliyeId String?     @unique // Satın alma irsaliyesi ID

  // E-Fatura fields
  efaturaStatus EFaturaStatus? @default(PENDING)
  efaturaEttn   String?        @unique
  efaturaXml    EFaturaXML?

  // Audit fields
  createdBy String? // User ID
  updatedBy String? // User ID
  deletedAt DateTime? // Soft delete
  deletedBy String? // User ID who deleted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cari              Cari                @relation(fields: [cariId], references: [id])
  kalemler          FaturaKalemi[]
  tahsilatlar       Tahsilat[] // Deprecated - Eski ilişki
  faturaTahsilatlar FaturaTahsilat[] // FIFO: Tahsilat dağılımları
  logs              FaturaLog[]
  purchaseOrder     PurchaseOrder?      @relation("PurchaseOrderFatura", fields: [purchaseOrderId], references: [id])
  satinAlmaSiparisi SatınAlmaSiparisi? @relation("SatınAlmaSiparisiFatura", fields: [satinAlmaSiparisiId], references: [id])
  irsaliye          SatisIrsaliyesi?    @relation("SatisIrsaliyesiFatura", fields: [deliveryNoteId], references: [id])
  satinAlmaIrsaliye SatınAlmaIrsaliyesi? @relation("SatınAlmaIrsaliyesiFatura", fields: [satinAlmaIrsaliyeId], references: [id])

  // Servis Modülü
  workOrder WorkOrder? @relation("WorkOrderInvoice")

  createdByUser User? @relation("FaturaCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("FaturaUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("FaturaDeletedBy", fields: [deletedBy], references: [id])

  @@unique([faturaNo, tenantId])
  @@index([tenantId])
  @@index([tenantId, faturaTipi])
  @@index([tenantId, durum])
  @@index([tenantId, tarih])
  @@index([cariId])
  @@index([durum])
  @@index([deliveryNoteId])
  @@map("faturalar")
}

model FaturaLog {
  id         String    @id @default(uuid())
  faturaId   String
  userId     String?
  actionType LogAction
  changes    String? // JSON string
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

