{
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/tmp/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/.next/**": true,
        "**/coverage/**": true,
        "**/uploads/**": true,
        "**/public/uploads/**": true,
        "**/.gemini/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/.next": true,
        "**/coverage": true,
        "**/uploads": true,
        "**/.gemini": true,
        "**/*.min.js": true
    },
    "typescript.tsdk": "node_modules/typescript/lib"
}