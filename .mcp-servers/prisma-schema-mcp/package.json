{
    "name": "@otomuhasebe/prisma-schema-mcp",
    "version": "1.0.0",
    "description": "MCP server for Prisma schema analysis and management",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
        "watch": "tsc --watch",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.4",
        "@prisma/client": "^6.19.0",
        "@prisma/internals": "^6.19.0"
    },
    "devDependencies": {
        "@types/estree": "^1.0.8",
        "@types/json-schema": "^7.0.15",
        "@types/node": "^22.10.2",
        "typescript": "^5.7.2"
    }
}
